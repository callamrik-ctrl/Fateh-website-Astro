---
const {
  title,
  description,
  canonical,
  ogImage = "https://fatehplumelec.com/assets/fateh-logo-clean.png",
  baseHref,
} = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  {baseHref && <base href={baseHref} />}
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="stylesheet" href="/styles.css?v=20260614-home-motion-v2" />
</head>
<body>
  <slot />
  <script is:inline src="/form-config.js?v=20260602-leads"></script>
  <script is:inline src="/script.js?v=20260614-home-motion-v2"></script>
</body>
</html>
