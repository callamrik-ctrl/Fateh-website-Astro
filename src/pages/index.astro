const canonical = "https://fatehplumelec.com/";

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  name: "Fateh Plumbing & Electric",
  url: canonical,
  telephone: "647-980-9211",
  email: "info@fatehplumelec.com",
  image: "https://fatehplumelec.com/assets/fateh-logo-clean.png",
  logo: "https://fatehplumelec.com/assets/fateh-logo-clean.png",
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Brampton",
    addressRegion: "ON",
    addressCountry: "CA",
  },
  areaServed: ["Brampton", "Mississauga", "Vaughan", "Caledon", "Etobicoke", "Greater Toronto Area"],
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
      opens: "00:00",
      closes: "23:59",
    },
  ],
  sameAs: [
    "https://www.facebook.com/fatehplumbing",
    "https://www.instagram.com/fateh_plumbing_electric",
  ],
  serviceType: [
    "Plumbing services",
    "Electrical services",
    "Emergency plumbing",
    "Emergency electrical service",
    "Drain cleaning",
    "Water heater repair",
    "Electrical panel upgrades",
    "EV charger installation",
    "Lighting installation",
    "Commercial plumbing and electrical service",
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Do you provide plumbing and electrical services in Brampton?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. Fateh Plumbing & Electric provides plumbing and electrical services from Brampton across nearby GTA communities for homeowners, landlords, businesses, restaurants, and property managers.",
      },
    },
    {
      "@type": "Question",
      name: "Can I call for emergency plumbing or electrical service?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. Call 647-980-9211 for urgent plumbing or electrical issues such as active leaks, sewer backups, burst pipes, sparks, burning smells, power loss, or repeated breaker trips.",
      },
    },
    {
      "@type": "Question",
      name: "Which plumbing services do you handle?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Plumbing services include emergency plumbing, drain cleaning, leak detection, pipe repair, sewer line repair, water heater repair, toilet and faucet repair, sump pump repair, and commercial plumbing.",
      },
    },
    {
      "@type": "Question",
      name: "Which electrical services do you handle?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Electrical services include emergency electrician calls, electrical repairs, panel upgrades, EV charger installation, lighting installation, wiring, smart home setup, and troubleshooting.",
      },
    },
    {
      "@type": "Question",
      name: "Do you serve areas outside Brampton?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. Fateh is based in Brampton and serves nearby GTA communities when scheduling allows. Call with your location and the service needed so we can help with the right plumbing or electrical service.",
      },
    },
  ],
};
