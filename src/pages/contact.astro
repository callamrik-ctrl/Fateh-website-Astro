---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

const title = "Contact Fateh Plumbing & Electric | Fateh";
const description = "Contact Fateh Plumbing & Electric in Brampton for plumbing, electrical, and commercial service. Free on-site assessment available.";
const canonical = "https://fatehplumelec.com/contact.html";

const businessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Fateh Plumbing & Electric",
  url: canonical,
  telephone: "647-980-9211",
  email: "info@fatehplumelec.com",
  image: "https://fatehplumelec.com/assets/fateh-logo-clean.png",
  logo: "https://fatehplumelec.com/assets/fateh-logo-clean.png",
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Brampton",
    addressRegion: "ON",
    addressCountry: "CA",
  },
  areaServed: ["Brampton", "Mississauga", "Vaughan", "Caledon", "Etobicoke", "Greater Toronto Area"],
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
      opens: "00:00",
      closes: "23:59",
    },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "How do I contact Fateh Plumbing & Electric?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Call 647-980-9211, email info@fatehplumelec.com, or send a service request through the contact page. Include your location, the issue, and whether the problem is urgent.",
      },
    },
    {
      "@type": "Question",
      name: "What should I include in a service request?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Include your name, phone number, email, service type, location, and a short description of the problem. For urgent leaks, sewer backups, or electrical hazards, calling is usually fastest.",
      },
    },
    {
      "@type": "Question",
      name: "Can I request emergency service online?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "You can send an online request, but urgent plumbing or electrical problems should also be called in at 647-980-9211 so the issue can be handled faster.",
      },
    },
    {
      "@type": "Question",
      name: "Do you handle plumbing and electrical requests?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Fateh Plumbing & Electric helps with plumbing service requests and connects electrical work with appropriate certified contractors where required.",
      },
    },
  ],
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <SiteHeader current="contact" />

  <main class="page-hero contact-hero">
    <div>
      <p class="eyebrow">Contact Fateh</p>
      <h1>Request plumbing or electrical service</h1>
      <p>Tell us what is happening, where you are located, and how urgent the issue is. For emergencies, calling is the fastest way to reach us.</p>
      <div class="hero-actions">
        <a class="button" href="tel:+16479809211">Call 647-980-9211</a>
        <a class="button secondary" href="mailto:info@fatehplumelec.com">Email info@fatehplumelec.com</a>
      </div>
    </div>
    <img
      class="page-hero-photo"
      src="https://images.unsplash.com/photo-1581092160607-ee22621dd758?auto=format&fit=crop&w=1400&q=80"
      alt="Home service technician preparing tools for a customer visit"
      width="700"
      height="460"
    >
  </main>

  <section class="content contact-section">
    <form class="contact-form contact-card" name="service-request">
      <p class="form-note">Send your request below. We will review it and contact you back as soon as possible.</p>

      <label>
        Name
        <input type="text" name="name" autocomplete="name" required>
      </label>

      <label>
        Phone
        <input type="tel" name="phone" autocomplete="tel" required>
      </label>

      <label>
        Email
        <input type="email" name="email" autocomplete="email">
      </label>

      <label>
        Service needed
        <select name="service">
          <option>Emergency Plumber</option>
          <option>Drain Cleaning</option>
          <option>Water Heater Repair</option>
          <option>Sewer Line Repair</option>
          <option>Leak Detection</option>
          <option>Pipe Repair</option>
          <option>Toilet or Faucet Repair</option>
          <option>Sump Pump Service</option>
          <option>Garbage Disposal Repair</option>
          <option>Emergency Electrician</option>
          <option>Panel Upgrade</option>
          <option>EV Charger Installation</option>
          <option>Lighting or Smart Home</option>
          <option>Commercial Service</option>
        </select>
      </label>

      <label>
        Message
        <textarea name="message" rows="6" placeholder="Describe the problem, location, and urgency." required></textarea>
      </label>

      <button class="button" type="submit">Send service request</button>
      <p class="success-message" hidden>Thanks. Your request has been sent. Fateh Plumbing & Electric will contact you soon.</p>
    </form>

    <aside class="quick-card contact-details-card">
      <p class="eyebrow">Business details</p>
      <h2>Call anytime</h2>
      <div class="contact-detail-list">
        <p><strong>Phone:</strong> <a href="tel:+16479809211">647-980-9211</a></p>
        <p><strong>Email:</strong> <a href="mailto:info@fatehplumelec.com">info@fatehplumelec.com</a></p>
        <p><strong>Location:</strong> Brampton, Ontario</p>
        <p><strong>Hours:</strong> Open 24 hours, 7 days a week</p>
      </div>
      <p>If water is actively leaking, shut off the nearest fixture valve or main water valve if it is safe to do so. For electrical emergencies, avoid touching unsafe wiring or sparking fixtures.</p>
      <div class="contact-link-cards" aria-label="Helpful contact links">
        <a href="emergency-plumber.html">
          <strong>Emergency plumber</strong>
          <span>Leaks, backups, burst pipes, and urgent plumbing calls.</span>
        </a>
        <a href="emergency-electrician.html">
          <strong>Emergency electrician</strong>
          <span>Sparking, power loss, breaker issues, and unsafe wiring.</span>
        </a>
        <a href="leak-detection.html">
          <strong>Leak detection</strong>
          <span>Hidden leaks, water stains, running meters, and damp areas.</span>
        </a>
      </div>
    </aside>
  </section>

  <section class="band">
    <div class="section-heading">
      <p class="eyebrow">Before you call</p>
      <h2>Helpful details to share</h2>
    </div>
    <div class="process-steps contact-before-steps">
      <article>
        <span>1</span>
        <p class="card-kicker">Urgency</p>
        <h3>Is water moving?</h3>
        <p>Tell us if water is leaking, backing up, overflowing, or shut off already.</p>
      </article>
      <article>
        <span>2</span>
        <p class="card-kicker">Location</p>
        <h3>Where is the issue?</h3>
        <p>Share the city, neighbourhood, room, fixture, unit, or building type.</p>
      </article>
      <article>
        <span>3</span>
        <p class="card-kicker">Safety</p>
        <h3>Any hazards?</h3>
        <p>Mention sewage, electrical sparks, burning smells, ceiling leaks, or standing water.</p>
      </article>
    </div>
  </section>

  <section class="band faq">
    <div class="section-heading">
      <p class="eyebrow">Contact FAQ</p>
      <h2>Common questions before contacting Fateh</h2>
    </div>
    <details>
      <summary>How do I contact Fateh Plumbing & Electric?</summary>
      <p>Call 647-980-9211, email info@fatehplumelec.com, or send a service request through this contact page.</p>
    </details>
    <details>
      <summary>What should I include in my message?</summary>
      <p>Include your location, the service needed, what you are seeing, and whether the problem is urgent.</p>
    </details>
    <details>
      <summary>Should I call instead of using the form?</summary>
      <p>For active leaks, sewer backups, no power, sparking, or unsafe wiring, call 647-980-9211 so the issue can be handled faster.</p>
    </details>
    <details>
      <summary>Do you respond to both plumbing and electrical requests?</summary>
      <p>Yes. Plumbing requests are handled directly, and electrical work is coordinated with properly certified contractors where required.</p>
    </details>
  </section>

  <SiteFooter />
</BaseLayout>
