---
import ElectricalServicePage from "../components/ElectricalServicePage.astro";

const title = "Panel Upgrade Brampton | Electrical Panel & Breaker Service";
const description = "Panel upgrade Brampton service for 100 amp to 200 amp panels, breaker issues, renovation loads, EV charger readiness, and safer electrical capacity.";
const canonical = "https://fatehplumelec.com/panel-upgrade.html";

const faqs = [
  ["When do I need a panel upgrade in Brampton?", "You may need a panel upgrade if breakers trip often, the panel is older, you are adding large appliances, finishing a basement, planning an EV charger, or the home needs more electrical capacity."],
  ["Can you upgrade a 100 amp panel to 200 amp service?", "Fateh Plumbing & Electric can help review the electrical panel, expected load, and service needs so you can plan a safer 100 amp to 200 amp upgrade path."],
  ["Is a breaker that keeps tripping a panel problem?", "It can be. Repeated breaker trips may come from overload, damaged wiring, a faulty appliance, or panel capacity concerns. Stop resetting the breaker repeatedly and call for electrical help."],
  ["Do EV chargers need a panel upgrade?", "Some homes can support a Level 2 EV charger with the existing panel, while others need capacity planning, load review, breaker work, or a panel upgrade before installation."],
  ["Do you help with electrical panel safety concerns?", "Yes. Call if the panel buzzes, smells hot, has visible damage, has overheating marks, has loose breakers, or if power is unreliable in part of the home."],
  ["Do you handle panel upgrades for renovations?", "Yes. Panel and breaker planning can support basement finishing, kitchens, additions, heavy appliances, lighting upgrades, and future EV charging."],
  ["Which Brampton areas do you serve?", "Fateh serves Brampton areas including Bramalea, Springdale, Castlemore, Mount Pleasant, Heart Lake, Fletcher's Meadow, Credit Valley, Peel Village, Downtown Brampton, and nearby communities."],
];

const schema = {
  "@context": "https://schema.org",
  "@type": "Electrician",
  name: "Fateh Plumbing & Electric",
  url: canonical,
  telephone: "647-980-9211",
  email: "info@fatehplumelec.com",
  image: "https://fatehplumelec.com/assets/fateh-logo-clean.png",
  logo: "https://fatehplumelec.com/assets/fateh-logo-clean.png",
  priceRange: "$$",
  address: { "@type": "PostalAddress", addressLocality: "Brampton", addressRegion: "ON", addressCountry: "CA" },
  areaServed: ["Brampton", "Bramalea", "Springdale", "Castlemore", "Mount Pleasant", "Mississauga", "Vaughan", "Caledon", "Etobicoke"],
  openingHoursSpecification: [{ "@type": "OpeningHoursSpecification", dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"], opens: "00:00", closes: "23:59" }],
  sameAs: ["https://www.facebook.com/fatehplumbing", "https://www.instagram.com/fateh_plumbing_electric"],
  serviceType: ["Panel upgrade", "Electrical panel replacement", "Breaker panel service", "100 amp to 200 amp upgrade", "EV charger panel readiness"],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map(([question, answer]) => ({ "@type": "Question", name: question, acceptedAnswer: { "@type": "Answer", text: answer } })),
};
---

<ElectricalServicePage
  title={title}
  description={description}
  canonical={canonical}
  schema={schema}
  faqSchema={faqSchema}
  eyebrow="Panel upgrade • Breaker panel service • Brampton"
  h1="Panel Upgrade Brampton"
  intro="Need more electrical capacity, safer breakers, or EV charger readiness? Fateh Plumbing & Electric helps Brampton homeowners and businesses plan panel upgrades, breaker panel service, and power improvements with clear next steps."
  heroImage="https://images.unsplash.com/photo-1621905251189-08b45d6a269e?auto=format&fit=crop&w=1400&q=80"
  heroAlt="Electrician checking an electrical panel for a Brampton panel upgrade"
  proof={["100A to 200A planning", "Breaker issues", "EV charger readiness"]}
  trust={[
    { title: "Capacity planning", text: "Review panel load for appliances, renovations, and EV chargers.", icon: "M5 4h14v18H5z M9 8h6 M9 12h2 M13 12h2 M9 16h2 M13 16h2" },
    { title: "Breaker concerns", text: "Help for repeated trips, buzzing, overheating, and old panels.", icon: "M13 2 5 14h6l-1 8 9-13h-6z" },
    { title: "Licensed & insured", text: "Professional electrical service for homes and businesses.", icon: "M4 5h16v14H4z M8 9h5 M8 13h8 M17 7l2 2 3-4" },
  ]}
  introHeading="Electrical panel upgrades for safer power capacity"
  introParagraphs={[
    "A panel upgrade is often needed when the electrical system no longer matches how the home or business uses power. Older panels, repeated breaker trips, new appliances, basement renovations, hot tubs, and EV chargers can all increase demand.",
    "Fateh Plumbing & Electric helps Brampton customers understand whether the concern is a breaker repair, wiring issue, load concern, or full electrical panel upgrade. The goal is to make the next step clear before work begins.",
    "Tell us what you are adding, what keeps tripping, whether the panel feels hot or buzzes, and whether you are planning future electrical work. Those details help us prepare the right service path.",
  ]}
  bookingTitle="Plan a panel upgrade"
  bookingText="Call Fateh and describe the panel, breaker issue, home load, renovation, EV charger plan, or safety concern."
  bookingItems={["100A to 200A upgrade planning", "Breaker and panel troubleshooting", "EV charger and renovation readiness"]}
  problemEyebrow="Common panel problems"
  problemHeading="Signs your electrical panel may need attention"
  problems={[
    { title: "Breakers trip often", text: "Repeated trips can point to overload, appliance trouble, damaged wiring, or capacity limits.", href: "emergency-electrician.html", link: "Breaker help" },
    { title: "Planning an EV charger", text: "Level 2 charging may need load review, breaker planning, and panel capacity checks.", href: "ev-charger-installation.html", link: "EV charger planning" },
    { title: "Older panel or fuse box", text: "Older equipment may not match modern appliance, renovation, and charging needs.", href: "tel:+16479809211", link: "Call Fateh" },
    { title: "Panel buzzes or smells hot", text: "Buzzing, heat, burning smells, or visible damage should be treated as urgent.", href: "emergency-electrician.html", link: "Emergency electrician" },
    { title: "Renovation power needs", text: "Basements, kitchens, additions, lighting, and new appliances may require more circuits.", href: "electrical-services.html", link: "Electrical service" },
    { title: "Not enough breaker space", text: "A crowded panel can limit future circuits and may need a cleaner capacity plan.", href: "tel:+16479809211", link: "Book panel review" },
  ]}
  safetyHeading="What to know before a panel upgrade"
  safetyParagraphs={[
    "A panel upgrade should be planned around real electrical demand: appliances, charging, heating and cooling equipment, finished basements, kitchens, workshops, and future additions.",
    "If there are urgent symptoms such as heat, buzzing, burning smell, sparks, or repeated breaker trips, do not wait for a planned upgrade conversation. Call for electrical help first so the unsafe symptom can be checked.",
  ]}
  safetyItems={["Current panel amperage if known", "What trips or stops working", "EV charger or renovation plans", "Large appliances being added", "Any heat, buzzing, or burning smell"]}
  relatedServices={[
    { title: "Emergency Electrician", href: "emergency-electrician.html", text: "Help for sparks, burning smells, breaker trips, partial power loss, and unsafe electrical issues.", link: "View emergency service", icon: "M13 2 5 14h6l-1 8 9-13h-6z" },
    { title: "EV Charger Installation", href: "ev-charger-installation.html", text: "Level 2 charger wiring, breaker sizing, charger placement, and electrical capacity planning.", link: "View EV chargers", icon: "M7 2v8 M17 2v8 M5 10h14 M8 22h8" },
    { title: "Lighting Installation", href: "lighting-smart-home.html", text: "Pot lights, fixtures, dimmers, smart switches, and lighting upgrades for homes and businesses.", link: "View lighting", icon: "M12 2a7 7 0 0 0-4 12c1 1 1 2 1 4h6c0-2 0-3 1-4a7 7 0 0 0-4-12z" },
    { title: "Brampton Electrician", href: "brampton-electrician.html", text: "Main electrical service page for Brampton repairs, upgrades, troubleshooting, and installations.", link: "View electrician page", icon: "M4 12h4l2-6 4 12 2-6h4" },
  ]}
  photoEyebrow="Panel and breaker service"
  photoHeading="A cleaner power plan for modern electrical needs"
  photoText="Panel work should account for what the property uses today and what it may need next: EV charging, finished basements, kitchens, appliances, lighting, and safer circuit distribution."
  photoItems={["Panel and breaker review", "Capacity planning for new electrical loads", "Clear explanation before work begins"]}
  photoImage="https://images.unsplash.com/photo-1610056494052-6a4f83a8368c?auto=format&fit=crop&w=1400&q=80"
  photoAlt="Electrical panel wiring and breaker service"
  proofHeading="Panel upgrades planned around the property"
  proofText="Fateh helps Brampton customers choose practical electrical next steps based on symptoms, capacity needs, safety concerns, and future plans."
  proofCards={[
    { title: "Brampton based", text: "Local electrical service for Brampton neighbourhoods and nearby GTA communities." },
    { title: "Future-ready planning", text: "Panel work can support EV chargers, renovations, appliances, and safer circuits." },
    { title: "Clear next step", text: "We help identify whether the issue is breaker, wiring, load, or panel related." },
  ]}
  processHeading="From panel concern to upgrade plan"
  processSteps={[
    { title: "Describe the need", text: "Tell us about breaker trips, panel age, EV charger plans, renovations, appliances, or safety concerns." },
    { title: "Review the load", text: "The technician checks panel condition, breaker layout, available capacity, and visible concerns." },
    { title: "Explain options", text: "You get a clear service path for breaker repair, wiring correction, panel work, or upgrade planning." },
    { title: "Complete and check", text: "After work is completed, the panel area and affected circuits are checked before use." },
  ]}
  areaText="If you are planning a panel upgrade, EV charger, renovation, appliance circuit, or dealing with breaker concerns, tell us your Brampton neighbourhood and what is happening."
  ctaEyebrow="Book panel service"
  ctaHeading="Planning a panel upgrade or dealing with breaker trips?"
  ctaText="Call Fateh Plumbing & Electric for panel upgrade planning, breaker panel service, EV charger readiness, and electrical capacity concerns in Brampton."
  faqEyebrow="Panel upgrade FAQ"
  faqHeading="Common questions about panel upgrades in Brampton"
  faqs={faqs.map(([question, answer]) => ({ question, answer }))}
/>
