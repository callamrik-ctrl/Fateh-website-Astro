---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

const title = "About Fateh Plumbing & Electric | Family-Owned Brampton Plumber & Electrician";
const description =
  "Learn about Fateh Plumbing & Electric, a family-owned plumbing and electrical service company in Brampton serving homes, rentals, businesses, and nearby GTA communities.";
const canonical = "https://fatehplumelec.com/about.html";

const serviceCards = [
  {
    title: "Plumbing service",
    text: "Emergency leaks, drain cleaning, water heaters, pipe repair, fixture work, sump pumps, and everyday home plumbing calls.",
    href: "services.html",
    link: "View plumbing services",
    icon: "water",
  },
  {
    title: "Electrical service",
    text: "Panels, electrical repair, EV chargers, lighting, switches, outlets, safety checks, and planned electrical upgrades.",
    href: "electrical-services.html",
    link: "View electrical services",
    icon: "bolt",
  },
  {
    title: "Commercial support",
    text: "Service for restaurants, retail units, rentals, plazas, property managers, and small businesses across Brampton and the GTA.",
    href: "commercial.html",
    link: "View commercial service",
    icon: "building",
  },
  {
    title: "Emergency calls",
    text: "Urgent help for active leaks, sewer backups, burst pipes, power concerns, unsafe wiring signs, and after-hours service needs.",
    href: "contact.html",
    link: "Request service",
    icon: "alert",
  },
];

const proofItems = [
  {
    title: "Family-owned and local",
    text: "A Brampton-based service company built around clear communication and practical help for nearby homes and businesses.",
  },
  {
    title: "Plumbing and electrical",
    text: "Customers can call one team for common plumbing, electrical, commercial, and emergency service needs.",
  },
  {
    title: "Built for real service calls",
    text: "The focus stays on the issue, the property, the safest next step, and the work needed to solve the problem properly.",
  },
];

const processSteps = [
  {
    step: "1",
    title: "Tell us what changed",
    text: "Describe the leak, drain, fixture, panel, circuit, charger, lighting, or business area that needs attention.",
  },
  {
    step: "2",
    title: "Match the right service",
    text: "We help connect the call to plumbing, electrical, commercial, emergency, repair, or installation support.",
  },
  {
    step: "3",
    title: "Review the next step",
    text: "You get a clear direction for booking, safety concerns, site access, and information that helps the visit go smoothly.",
  },
];

const faqs = [
  {
    question: "Is Fateh Plumbing & Electric family-owned?",
    answer:
      "Yes. Fateh Plumbing & Electric is a family-owned service company based in Brampton, Ontario.",
  },
  {
    question: "Do you provide both plumbing and electrical service?",
    answer:
      "Yes. Customers call Fateh Plumbing & Electric for plumbing repairs, drain service, water heaters, electrical repairs, panels, EV chargers, lighting, commercial work, and emergency service.",
  },
  {
    question: "What areas do you serve?",
    answer:
      "Fateh Plumbing & Electric serves Brampton and nearby Greater Toronto Area communities, including Mississauga, Caledon, Vaughan, Etobicoke, North York, and Scarborough.",
  },
  {
    question: "Can you help homes, rentals, and businesses?",
    answer:
      "Yes. Service is available for homeowners, landlords, rentals, restaurants, retail units, small businesses, and property managers.",
  },
];

const aboutSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["LocalBusiness", "Plumber", "Electrician"],
      "@id": "https://fatehplumelec.com/#business",
      name: "Fateh Plumbing & Electric",
      url: "https://fatehplumelec.com/",
      telephone: "647-980-9211",
      email: "info@fatehplumelec.com",
      image: "https://fatehplumelec.com/assets/fateh-logo-clean.png",
      logo: "https://fatehplumelec.com/assets/fateh-logo-clean.png",
      priceRange: "$$",
      address: {
        "@type": "PostalAddress",
        addressLocality: "Brampton",
        addressRegion: "ON",
        addressCountry: "CA",
      },
      areaServed: ["Brampton", "Mississauga", "Caledon", "Vaughan", "Etobicoke", "Greater Toronto Area"],
      serviceType: [
        "Plumbing service",
        "Electrical service",
        "Emergency plumbing",
        "Emergency electrician",
        "Commercial plumbing",
        "Drain cleaning",
        "Water heater repair",
        "Electrical panel upgrades",
        "EV charger installation",
      ],
    },
    {
      "@type": "AboutPage",
      "@id": `${canonical}#about`,
      url: canonical,
      name: title,
      description,
      about: {
        "@id": "https://fatehplumelec.com/#business",
      },
      inLanguage: "en-CA",
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${canonical}#breadcrumb`,
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: "https://fatehplumelec.com/",
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "About",
          item: canonical,
        },
      ],
    },
    {
      "@type": "FAQPage",
      "@id": `${canonical}#faq`,
      mainEntity: faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: faq.answer,
        },
      })),
    },
  ],
};

const iconPaths = {
  alert: '<path d="M12 3 2.8 19h18.4L12 3z"></path><path d="M12 8v5"></path><path d="M12 16h.01"></path>',
  bolt: '<path d="M13 2 4 14h7l-1 8 9-12h-7l1-8z"></path>',
  building: '<path d="M3 21h18"></path><path d="M6 21V7l6-4 6 4v14"></path><path d="M9 21v-6h6v6"></path><path d="M9 9h.01"></path><path d="M12 9h.01"></path><path d="M15 9h.01"></path>',
  water: '<path d="M12 3s6 6.1 6 10a6 6 0 0 1-12 0c0-3.9 6-10 6-10z"></path>',
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <SiteHeader current="about" />

  <script type="application/ld+json" set:html={JSON.stringify(aboutSchema)} />

  <main class="page-hero">
    <div>
      <p class="eyebrow">About Fateh</p>
      <h1>Family-owned plumbing and electrical service in Brampton</h1>
      <p>
        Fateh Plumbing & Electric is a family-owned Brampton service company helping homeowners, landlords,
        restaurants, small businesses, and property managers with plumbing, electrical, commercial, and emergency calls
        across nearby GTA communities.
      </p>
      <div class="hero-actions">
        <a class="button" href="tel:+16479809211">Call 647-980-9211</a>
        <a class="button secondary" href="contact.html">Request service</a>
      </div>
    </div>
    <img
      class="page-hero-photo"
      src="https://images.unsplash.com/photo-1581092160562-40aa08e78837?auto=format&fit=crop&w=1400&q=80"
      alt="Home service technician preparing tools for a plumbing and electrical service call"
      width="700"
      height="460"
    />
  </main>

  <section class="content">
    <div>
      <p class="eyebrow">Local service company</p>
      <h2>One call for practical plumbing and electrical help</h2>
      <p>
        Customers call Fateh Plumbing & Electric when they need clear help with a leak, clogged drain, water heater,
        electrical panel, EV charger, lighting upgrade, fixture repair, or urgent service concern. The goal is simple:
        understand the problem, match the right service, and make the next step easy to book.
      </p>
      <p>
        From Brampton, the team supports residential properties, rentals, commercial kitchens, retail units, plazas,
        restaurants, and managed properties across the Greater Toronto Area. Service pages are organized so visitors can
        quickly find the right path for plumbing, electrical, emergency, and commercial needs.
      </p>
    </div>
    <aside class="quick-card">
      <h2>Quick facts</h2>
      <ul class="mini-links">
        <li>Family-owned business</li>
        <li>Based in Brampton, Ontario</li>
        <li>Plumbing and electrical service</li>
        <li>Residential, rental, and commercial properties</li>
        <li><a href="contact.html">Contact Fateh</a></li>
      </ul>
    </aside>
  </section>

  <section class="band service-hub-band">
    <div class="section-heading">
      <p class="eyebrow">What we help with</p>
      <h2>Service paths for homes and businesses</h2>
    </div>
    <div class="service-hub-grid">
      {serviceCards.map((card) => (
        <article>
          <span class="hub-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false" set:html={iconPaths[card.icon]} />
          </span>
          <h3><a href={card.href}>{card.title}</a></h3>
          <p>{card.text}</p>
          <a class="text-link" href={card.href}>{card.link}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="proof-band">
    <div>
      <p class="eyebrow">Why customers call Fateh</p>
      <h2>Local service with clear communication</h2>
      <p>
        Plumbing and electrical problems can disrupt a home or business quickly. Fateh keeps the focus on the property,
        the urgency, the right service path, and a practical plan for the work.
      </p>
    </div>
    <div class="proof-grid">
      {proofItems.map((item) => (
        <article>
          <strong>{item.title}</strong>
          <span>{item.text}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="band process-band">
    <div class="section-heading">
      <p class="eyebrow">How service starts</p>
      <h2>A simple way to explain the problem</h2>
    </div>
    <div class="process-steps">
      {processSteps.map((item) => (
        <article>
          <span>{item.step}</span>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="brampton-cta-band">
    <div>
      <p class="eyebrow">Book service</p>
      <h2>Need a Brampton plumber or electrician?</h2>
      <p>
        Call Fateh Plumbing & Electric for plumbing, electrical, commercial, and emergency service help across Brampton
        and nearby GTA communities.
      </p>
    </div>
    <a class="button" href="tel:+16479809211">Call 647-980-9211</a>
  </section>

  <section class="band faq">
    <div class="section-heading">
      <p class="eyebrow">FAQ</p>
      <h2>Common questions about Fateh Plumbing & Electric</h2>
    </div>
    {faqs.map((faq) => (
      <details>
        <summary>{faq.question}</summary>
        <p>{faq.answer}</p>
      </details>
    ))}
  </section>

  <SiteFooter />
</BaseLayout>
