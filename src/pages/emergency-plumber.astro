---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Emergency Plumber Brampton | 24/7 Urgent Plumbing Repair";
const description = "Need an emergency plumber in Brampton? Call Fateh Plumbing & Electric for burst pipes, sewer backups, active leaks, clogged drains, overflowing toilets, and urgent plumbing repairs.";
const canonical = "https://fatehplumelec.com/emergency-plumber.html";

const plumberSchema = {
  "@context": "https://schema.org",
  "@type": "Plumber",
  name: "Fateh Plumbing & Electric",
  url: canonical,
  telephone: "647-980-9211",
  email: "info@fatehplumelec.com",
  image: "https://fatehplumelec.com/assets/fateh-logo-clean.png",
  logo: "https://fatehplumelec.com/assets/fateh-logo-clean.png",
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Brampton",
    addressRegion: "ON",
    addressCountry: "CA",
  },
  areaServed: ["Brampton", "Bramalea", "Springdale", "Castlemore", "Mount Pleasant", "Mississauga", "Vaughan", "Caledon", "Etobicoke"],
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
      opens: "00:00",
      closes: "23:59",
    },
  ],
  sameAs: [
    "https://www.facebook.com/fatehplumbing",
    "https://www.instagram.com/fateh_plumbing_electric",
  ],
  serviceType: [
    "Emergency plumbing",
    "24 hour plumber",
    "Burst pipe repair",
    "Sewer backup service",
    "Overflowing toilet repair",
    "Emergency leak repair",
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Do you offer emergency plumbing in Brampton?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. Fateh Plumbing & Electric helps with urgent plumbing problems in Brampton, including burst pipes, active leaks, overflowing toilets, sewer backups, and no-hot-water situations.",
      },
    },
    {
      "@type": "Question",
      name: "What should I do before an emergency plumber arrives?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "If it is safe, shut off the nearest fixture valve or the main water shutoff. Avoid standing water near electrical equipment, move valuables away from water, and call 647-980-9211.",
      },
    },
    {
      "@type": "Question",
      name: "Can you help with sewer backups and drain emergencies?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. Fateh Plumbing & Electric helps with sewer backups, floor drain overflows, recurring main drain blockages, clogged toilets, kitchen drain backups, and urgent drain cleaning.",
      },
    },
    {
      "@type": "Question",
      name: "Can a leaking water heater be an emergency?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "A leaking water heater can become urgent, especially if water is spreading or the tank is actively leaking. Shut off the water supply if safe and call for help.",
      },
    },
  ],
};
---

