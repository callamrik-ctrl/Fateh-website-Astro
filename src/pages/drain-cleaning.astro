    "https://www.facebook.com/fatehplumbing",
    "https://www.instagram.com/fateh_plumbing_electric",
  ],
  serviceType: [
    "Drain cleaning",
    "Clogged drain repair",
    "Kitchen sink drain cleaning",
    "Clogged toilet service",
    "Main drain cleaning",
    "Sewer drain cleaning",
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Do you provide drain cleaning in Brampton?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. Fateh Plumbing & Electric provides drain cleaning in Brampton for clogged sinks, toilets, tubs, floor drains, kitchen drains, main drains, and recurring backups.",
      },
    },
    {
      "@type": "Question",
      name: "When is a clogged drain an emergency?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "A clogged drain can be urgent if sewage is backing up, multiple fixtures are blocked, water is overflowing, or the home has no working toilet. Call for emergency plumbing help in those situations.",
      },
    },
    {
      "@type": "Question",
      name: "Can you clear a clogged toilet or kitchen sink?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. Fateh Plumbing & Electric helps with clogged toilets, clogged kitchen sinks, bathroom sink clogs, tub and shower drains, floor drains, and slow drains.",
      },
    },
    {
      "@type": "Question",
      name: "Why does my drain keep clogging again?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Recurring clogs can be caused by grease, hair, soap buildup, roots, pipe slope issues, damaged sewer lines, or a blockage deeper in the main drain.",
      },
    },
    {
      "@type": "Question",
      name: "Do I need sewer line repair or drain cleaning?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "A single slow sink may only need drain cleaning. Multiple slow fixtures, basement backups, sewage smell, or recurring main drain clogs may need sewer line inspection or repair.",
      },
    },
  ],
};
