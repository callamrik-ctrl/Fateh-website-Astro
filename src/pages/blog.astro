---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

const title = "Plumbing & Electrical Blog | Brampton Home Service Tips";
const description = "Read Fateh Plumbing & Electric's Brampton plumbing and electrical blog for practical tips on leaks, drains, panels, EV chargers, lighting, safety, and home maintenance.";
const canonical = "https://fatehplumelec.com/blog.html";

const featuredPosts = [
  {
    category: "Electrical troubleshooting",
    title: "Why Does My Breaker Keep Tripping?",
    description:
      "A Brampton electrician guide to overloaded circuits, summer AC load, random breaker trips, short circuits, ground faults, and older panel concerns.",
    href: "/blog/breaker-keeps-tripping",
    cta: "Read breaker guide",
    icon: "bolt",
    date: "January 8, 2026",
  },
  {
    category: "Sewer line guide",
    title: "7 Signs Your Main Sewer Line Is Clogged",
    description:
      "Learn the sewer backup signs Brampton homeowners should watch for, from multiple drains backing up to sewer smell and tree root intrusion.",
    href: "/blog/signs-main-sewer-line-clogged",
    cta: "Read sewer guide",
    icon: "drain",
    date: "January 15, 2026",
  },
  {
    category: "Basement flood prevention",
    title: "Does Your Brampton Basement Need a Backwater Valve?",
    description:
      "A local guide to backwater valves, sewer backup prevention, summer storm surcharge risk, basement flooding, and Region of Peel rebate basics.",
    href: "/blog/backwater-valve-brampton-guide",
    cta: "Read valve guide",
    icon: "water",
    date: "January 22, 2026",
  },
  {
    category: "Emergency plumbing",
    title: "What to do before an emergency plumber arrives",
    description:
      "Shut off the nearest valve if safe, avoid using affected fixtures, keep electrical items away from water, and describe the leak, backup, or fixture problem clearly when you call.",
    href: "emergency-plumber.html",
    cta: "Emergency plumbing",
    icon: "alert",
  },
  {
    category: "Electrical safety",
    title: "Signs your electrical panel may need an upgrade",
    description:
      "Breaker trips, renovation plans, EV charging, older fuse equipment, warm panel areas, or flickering lights can all point to the need for a licensed electrical review.",
    href: "panel-upgrade.html",
    cta: "Panel upgrades",
    icon: "bolt",
  },
  {
    category: "Drain care",
    title: "How to prevent repeat drain clogs",
    description:
      "Grease, food scraps, hair, wipes, and recurring slow drains are early warning signs. Catching the issue early can help prevent a larger main drain or sewer backup.",
    href: "drain-cleaning.html",
    cta: "Drain cleaning",
    icon: "drain",
  },
];

const guideTopics = [
  {
    title: "Water heater warning signs",
    text: "No hot water, rust-coloured water, popping sounds, leaks near the tank, or temperature swings are worth checking before the problem grows.",
    href: "water-heater-repair.html",
  },
  {
    title: "Leak clues around the home",
    text: "Ceiling stains, damp cabinets, bubbling paint, a running meter, or unexplained moisture can point to a hidden plumbing leak.",
    href: "leak-detection.html",
  },
  {
    title: "EV charger planning",
    text: "Panel capacity, parking location, charger model, wire route, and permit requirements should be reviewed before installation starts.",
    href: "ev-charger-installation.html",
  },
  {
    title: "Lighting and smart home updates",
    text: "Pot lights, outdoor lighting, ceiling fans, and smart switches work best when wiring, controls, and room use are planned together.",
    href: "lighting-smart-home.html",
  },
];

const maintenanceTopics = [
  {
    title: "Before a plumbing emergency",
    text: "Know where the main shutoff valve is, avoid using backed-up fixtures, and call quickly when water is actively leaking or sewage is involved.",
    href: "emergency-plumber.html",
  },
  {
    title: "Before electrical work",
    text: "Note breaker trips, flickering lights, warm devices, charger plans, and any recent renovations so the electrician can review the right load and wiring details.",
    href: "electrical-services.html",
  },
  {
    title: "Before commercial service",
    text: "Restaurants, retail units, and managed properties can reduce disruption by tracking recurring drain, fixture, leak, and maintenance issues by location.",
    href: "commercial.html",
  },
];

const warningSigns = [
  {
    title: "Call for plumbing help",
    text: "Active leaks, sewage smell, drain backups, no hot water, burst pipes, ceiling stains, or water around fixtures should be checked before damage spreads.",
    href: "services.html",
  },
  {
    title: "Call for electrical help",
    text: "Burning smells, sparks, warm panels, repeated breaker trips, buzzing outlets, or flickering lights should be treated as electrical warning signs.",
    href: "electrical-repair.html",
  },
  {
    title: "Plan upgrades early",
    text: "EV chargers, pot lights, outdoor lighting, new appliances, finished basements, and commercial changes are easier to quote when the layout is planned early.",
    href: "contact.html",
  },
];

const processSteps = [
  {
    step: "1",
    title: "Match the symptom",
    text: "Start with what you can see, hear, or smell: water, sewage, breaker trips, no hot water, flickering lights, or a slow drain.",
  },
  {
    step: "2",
    title: "Use the service path",
    text: "Open the related service page for the issue so you can see what information is helpful before calling.",
  },
  {
    step: "3",
    title: "Call when it is urgent",
    text: "Active leaks, sewer backups, burning smells, sparks, or warm electrical equipment should be handled quickly.",
  },
  {
    step: "4",
    title: "Plan bigger work",
    text: "For upgrades, note the room, panel, fixture, appliance, charger, or business area involved before requesting service.",
  },
];

const faqs = [
  {
    question: "What is this blog for?",
    answer:
      "This blog helps Brampton homeowners, landlords, restaurants, and property managers understand common plumbing and electrical problems before booking service.",
  },
  {
    question: "Can blog tips replace a plumber or electrician?",
    answer:
      "No. The articles are general guidance only. Active leaks, sewer backups, electrical burning smells, warm panels, sparks, or unsafe wiring should be handled by a qualified professional.",
  },
  {
    question: "What topics does the blog cover?",
    answer:
      "The blog covers practical plumbing, electrical, commercial, emergency, and maintenance topics for homeowners, businesses, landlords, and property managers.",
  },
  {
    question: "How do I choose the right service page?",
    answer:
      "Start with the symptom. Use emergency plumbing for urgent leaks or backups, drain cleaning for slow or blocked drains, panel upgrades for capacity concerns, and electrical services for wiring, panels, lighting, and safety issues.",
  },
];

const blogSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Blog",
      "@id": `${canonical}#blog`,
      name: "Fateh Plumbing & Electric Blog",
      url: canonical,
      description,
      publisher: {
        "@id": "https://fatehplumelec.com/#business",
      },
      about: [
        "Plumbing tips",
        "Electrical safety",
        "Drain cleaning",
        "Water heater repair",
        "EV charger installation",
        "Brampton home maintenance",
      ],
      inLanguage: "en-CA",
    },
    {
      "@type": ["LocalBusiness", "Plumber", "Electrician"],
      "@id": "https://fatehplumelec.com/#business",
      name: "Fateh Plumbing & Electric",
      url: "https://fatehplumelec.com/",
      telephone: "647-980-9211",
      email: "info@fatehplumelec.com",
      image: "https://fatehplumelec.com/assets/fateh-logo-clean.png",
      logo: "https://fatehplumelec.com/assets/fateh-logo-clean.png",
      address: {
        "@type": "PostalAddress",
        addressLocality: "Brampton",
        addressRegion: "ON",
        addressCountry: "CA",
      },
      areaServed: ["Brampton", "Mississauga", "Etobicoke", "North York", "Scarborough", "Greater Toronto Area"],
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${canonical}#breadcrumb`,
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: "https://fatehplumelec.com/",
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Blog",
          item: canonical,
        },
      ],
    },
    {
      "@type": "FAQPage",
      "@id": `${canonical}#faq`,
      mainEntity: faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: faq.answer,
        },
      })),
    },
  ],
};

const iconPaths = {
  alert: '<path d="M12 3 2.8 19h18.4L12 3z"></path><path d="M12 8v5"></path><path d="M12 16h.01"></path>',
  bolt: '<path d="M13 2 4 14h7l-1 8 9-12h-7l1-8z"></path>',
  drain: '<path d="M4 7h16"></path><path d="M7 7v5a5 5 0 0 0 10 0V7"></path><path d="M8 17c1.2-1 2.4-1 3.6 0s2.4 1 3.6 0"></path>',
  water: '<path d="M12 3s6 6.1 6 10a6 6 0 0 1-12 0c0-3.9 6-10 6-10z"></path>',
  plug: '<path d="M8 3v6"></path><path d="M16 3v6"></path><path d="M7 9h10v3a5 5 0 0 1-10 0V9z"></path><path d="M12 17v4"></path>',
};

---

<BaseLayout title={title} description={description} canonical={canonical}>
  <SiteHeader current="blog" />

  <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />

  <main class="page-hero">
    <div>
      <p class="eyebrow">Blog</p>
      <h1>Plumbing and electrical tips for homeowners and businesses</h1>
      <p>
        Practical home service guidance from Fateh Plumbing & Electric for leaks, clogged drains, water heaters,
        electrical panels, EV chargers, lighting, safety checks, and maintenance planning across Brampton and nearby GTA communities.
      </p>
      <div class="hero-actions">
        <a class="button" href="tel:+16479809211">Call 647-980-9211</a>
        <a class="button secondary" href="contact.html">Request service</a>
      </div>
    </div>
    <img
      class="page-hero-photo"
      src="https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&w=1400&q=80"
      alt="Technician reviewing plumbing and electrical service notes"
      width="700"
      height="460"
    />
  </main>

  <section class="band service-hub-band">
    <div class="section-heading">
      <p class="eyebrow">Featured guides</p>
      <h2>Quick help before you book service</h2>
    </div>
    <div class="service-hub-grid">
      {featuredPosts.map((post) => (
        <article>
          <span class="hub-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false" set:html={iconPaths[post.icon]} />
          </span>
          <p class="card-kicker">{post.category}</p>
          <h3><a href={post.href}>{post.title}</a></h3>
          {post.date && <small class="blog-card-date">{post.date}</small>}
          <p>{post.description}</p>
          <a class="text-link" href={post.href}>{post.cta}</a>
        </article>
      ))}
      <article>
        <span class="hub-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false" set:html={iconPaths.water} />
        </span>
        <p class="card-kicker">Water heaters</p>
        <h3><a href="water-heater-repair.html">No hot water or leaking tank</a></h3>
        <p>Temperature changes, tank leaks, rust-coloured water, or no hot water can point to a water heater service issue.</p>
        <a class="text-link" href="water-heater-repair.html">Water heater repair</a>
      </article>
    </div>
  </section>

  <section class="content">
    <div>
      <h2>Home service advice written around real local problems</h2>
      <p>
        This blog answers common questions customers ask before they call: whether a leak is urgent,
        why a drain keeps slowing down, what an older electrical panel can handle, and how to plan work such as
        <a href="ev-charger-installation.html"> EV charger installation</a>,
        <a href="pot-light-installation.html"> pot lights</a>, or
        <a href="water-heater-repair.html"> water heater repair</a>.
      </p>
      <p>
        For urgent issues, skip the reading and contact the right service directly. Common starting points are
        <a href="emergency-plumber.html"> emergency plumbing</a>,
        <a href="drain-cleaning.html"> drain cleaning</a>,
        <a href="electrical-repair.html"> electrical repair</a>, and
        <a href="emergency-electrician.html"> emergency electrician service</a>.
      </p>
    </div>
    <aside class="quick-card">
      <h2>Popular topics</h2>
      <ul class="mini-links">
        <li><a href="services.html">Plumbing services</a></li>
        <li><a href="electrical-services.html">Electrical services</a></li>
        <li><a href="commercial.html">Commercial service</a></li>
        <li><a href="brampton-plumber.html">Brampton plumber</a></li>
        <li><a href="brampton-electrician.html">Brampton electrician</a></li>
      </ul>
    </aside>
  </section>

  <section class="band problem-band">
    <div class="section-heading">
      <p class="eyebrow">More guides</p>
      <h2>Browse by service need</h2>
    </div>
    <div class="problem-grid">
      {guideTopics.map((topic) => (
        <article>
          <strong>{topic.title}</strong>
          <p>{topic.text}</p>
          <a href={topic.href}>View service guide</a>
        </article>
      ))}
    </div>
  </section>

  <section class="proof-band">
    <div>
      <p class="eyebrow">Practical service tips</p>
      <h2>Useful information before a plumber or electrician arrives</h2>
      <p>
        The best first step is simple: know what changed, when it started, and whether the issue is getting worse.
        That helps the service call focus on the right fixture, drain, panel, circuit, appliance, or commercial area.
      </p>
    </div>
    <div class="proof-grid">
      {maintenanceTopics.map((topic) => (
        <article>
          <strong>{topic.title}</strong>
          <span>{topic.text}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="content">
    <div>
      <h2>Know when to call for service</h2>
      <p>
        Some issues can wait for a scheduled visit, while others need faster attention. Use the signs below as a
        practical starting point, then call if the issue involves active water, sewage, heat, burning smells, sparks,
        or anything that feels unsafe.
      </p>
    </div>
    <aside class="quick-card">
      <h2>Fast routes</h2>
      <ul class="mini-links">
        <li><a href="emergency-plumber.html">Emergency plumber</a></li>
        <li><a href="emergency-electrician.html">Emergency electrician</a></li>
        <li><a href="contact.html">Request service</a></li>
      </ul>
    </aside>
  </section>

  <section class="band service-hub-band">
    <div class="section-heading">
      <p class="eyebrow">Warning signs</p>
      <h2>Choose the right next step</h2>
    </div>
    <div class="service-hub-grid">
      {warningSigns.map((topic) => (
        <article>
          <span class="hub-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false" set:html={topic.href.includes("electrical") ? iconPaths.bolt : topic.href.includes("contact") ? iconPaths.plug : iconPaths.alert} />
          </span>
          <h3><a href={topic.href}>{topic.title}</a></h3>
          <p>{topic.text}</p>
          <a class="text-link" href={topic.href}>View next step</a>
        </article>
      ))}
    </div>
  </section>

  <section class="band process-band">
    <div class="section-heading">
      <p class="eyebrow">How to use the blog</p>
      <h2>From symptom to service page</h2>
    </div>
    <div class="process-steps">
      {processSteps.map((item) => (
        <article>
          <span>{item.step}</span>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="brampton-cta-band">
    <div>
      <p class="eyebrow">Need help?</p>
      <h2>Talk to Fateh Plumbing & Electric about the issue you are seeing</h2>
      <p>
        Call for plumbing, electrical, commercial, or emergency service in Brampton and nearby GTA communities.
        Describe the symptom and we will help you choose the right next step.
      </p>
    </div>
    <a class="button" href="tel:+16479809211">Call 647-980-9211</a>
  </section>

  <section class="band faq">
    <div class="section-heading">
      <p class="eyebrow">Blog FAQ</p>
      <h2>Common questions about the Fateh service blog</h2>
    </div>
    {faqs.map((faq) => (
      <details>
        <summary>{faq.question}</summary>
        <p>{faq.answer}</p>
      </details>
    ))}
  </section>

  <SiteFooter />
</BaseLayout>
