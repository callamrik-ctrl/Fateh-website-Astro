---
import ElectricalServicePage from "../components/ElectricalServicePage.astro";

const title = "EV Charger Installation Brampton | Fateh";
const description = "EV charger installation Brampton service for home charging, panel review, dedicated circuits, and setup. Free on-site assessment.";
const canonical = "https://fatehplumelec.com/ev-charger-installation.html";

const faqs = [
  ["Do I need an electrician to install a Level 2 EV charger?", "Yes. A Level 2 EV charger normally needs a dedicated electrical circuit, correct breaker sizing, wiring, mounting, and a panel capacity review."],
  ["Can you install an EV charger in a Brampton garage?", "Yes. Fateh Plumbing & Electric helps with garage EV charger installation, charger placement, wiring route planning, dedicated circuits, and panel readiness in Brampton homes."],
  ["Will my panel support an EV charger?", "It depends on your existing panel capacity, current home load, charger size, and other appliances. Some homes are ready, while others need breaker planning or a panel upgrade."],
  ["What is the best charger location?", "The best location usually depends on parking position, cable reach, panel location, wall space, weather exposure, and how you normally charge the vehicle."],
  ["Can you install Tesla and other EV chargers?", "Fateh can help with common home EV charging setups, including wall-mounted Level 2 chargers and dedicated charging circuits. Tell us your charger model when you call."],
  ["Should I install a 40 amp or 50 amp EV charger circuit?", "The right circuit depends on the charger, vehicle, panel capacity, wiring route, and manufacturer requirements. The electrician can review the safest practical option."],
  ["Which Brampton areas do you serve?", "Fateh serves Brampton areas including Bramalea, Springdale, Castlemore, Mount Pleasant, Heart Lake, Fletcher's Meadow, Credit Valley, Peel Village, Downtown Brampton, and nearby communities."],
];

const schema = {
  "@context": "https://schema.org",
  "@type": "Electrician",
  name: "Fateh Plumbing & Electric",
  url: canonical,
  telephone: "647-980-9211",
  email: "info@fatehplumelec.com",
  image: "https://fatehplumelec.com/assets/fateh-logo-clean.png",
  logo: "https://fatehplumelec.com/assets/fateh-logo-clean.png",
  priceRange: "$$",
  address: { "@type": "PostalAddress", addressLocality: "Brampton", addressRegion: "ON", addressCountry: "CA" },
  areaServed: ["Brampton", "Bramalea", "Springdale", "Castlemore", "Mount Pleasant", "Mississauga", "Vaughan", "Caledon", "Etobicoke"],
  openingHoursSpecification: [{ "@type": "OpeningHoursSpecification", dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"], opens: "00:00", closes: "23:59" }],
  sameAs: ["https://www.facebook.com/fatehplumbing", "https://www.instagram.com/fateh_plumbing_electric"],
  serviceType: ["EV charger installation", "Level 2 charger installation", "Tesla charger installation", "Dedicated EV circuit", "Home EV charging electrician"],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map(([question, answer]) => ({ "@type": "Question", name: question, acceptedAnswer: { "@type": "Answer", text: answer } })),
};
---

<ElectricalServicePage
  title={title}
  description={description}
  canonical={canonical}
  schema={schema}
  faqSchema={faqSchema}
  eyebrow="EV charger installation • Level 2 charging • Brampton"
  h1="EV Charger Installation Brampton"
  intro="Ready to charge your electric vehicle at home? Fateh Plumbing & Electric installs EV charger circuits and Level 2 home charging setups in Brampton with panel checks, breaker planning, wiring, and clean charger placement."
  heroImage="https://images.unsplash.com/photo-1593941707882-a5bba14938c7?auto=format&fit=crop&w=1400&q=80"
  heroAlt="Electric vehicle charging at home with Level 2 charger installation"
  proof={["Level 2 chargers", "Garage charging", "Panel readiness"]}
  trust={[
    { title: "Dedicated circuits", text: "Proper wiring and breaker planning for home EV charging.", icon: "M7 2v8 M17 2v8 M5 10h14 M8 22h8" },
    { title: "Panel checks", text: "Review existing capacity before charger installation.", icon: "M5 4h14v18H5z M9 8h6 M9 12h2 M13 12h2" },
    { title: "Clean placement", text: "Charger location planned around parking, cable reach, and daily use.", icon: "M4 5h16v14H4z M8 9h5 M8 13h8 M17 7l2 2 3-4" },
  ]}
  introHeading="Home EV charging installed around your panel and parking setup"
  introParagraphs={[
    "A Level 2 EV charger gives faster, more convenient home charging, but the installation should be planned around the existing panel, vehicle, charger model, wiring route, and where the car parks.",
    "Fateh Plumbing & Electric helps Brampton customers with EV charger installation, dedicated circuits, breaker sizing, garage charging, charger placement, and panel readiness checks.",
    "When you call, tell us your EV model, charger model if you have one, where the panel is located, where the vehicle parks, and whether the charger will be indoors or outdoors.",
  ]}
  bookingTitle="Book EV charger installation"
  bookingText="Tell us your charger model, parking location, panel location, and whether you want garage or outdoor charging."
  bookingItems={["Level 2 EV charger installation", "Dedicated EV charging circuits", "Panel readiness and breaker planning"]}
  problemEyebrow="EV charger planning"
  problemHeading="What to decide before installing a home charger"
  problems={[
    { title: "Panel capacity", text: "Your panel must support the charger plus the rest of the home electrical load.", href: "panel-upgrade.html", link: "Panel readiness" },
    { title: "Charger location", text: "The best spot depends on parking, cable reach, panel distance, and wall space.", href: "tel:+16479809211", link: "Call Fateh" },
    { title: "Dedicated circuit", text: "Level 2 chargers normally need a dedicated circuit sized to the charger and wiring.", href: "electrical-services.html", link: "Electrical service" },
    { title: "Garage charging", text: "Garage installs should be placed for daily use without cable strain or awkward parking.", href: "tel:+16479809211", link: "Book install" },
    { title: "Outdoor charging", text: "Outdoor charger placement needs suitable equipment, mounting, and weather-aware planning.", href: "tel:+16479809211", link: "Ask about outdoor" },
    { title: "Breaker trips after charging", text: "Tripping during charging can point to load, breaker, wiring, or charger concerns.", href: "emergency-electrician.html", link: "Electrical help" },
  ]}
  safetyHeading="What affects EV charger installation cost and planning"
  safetyParagraphs={[
    "The installation path depends on charger amperage, panel capacity, distance from panel to charger, wall type, indoor or outdoor placement, wiring route, and whether any panel work is needed.",
    "A charger should not simply be added wherever it is convenient. The safest setup is one that matches the charger instructions, electrical capacity, and how the vehicle will be used every day.",
  ]}
  safetyItems={["Vehicle and charger model", "Panel location", "Preferred charger location", "Indoor or outdoor install", "Distance from panel to parking spot"]}
  relatedServices={[
    { title: "Panel Upgrade", href: "panel-upgrade.html", text: "Panel capacity planning for EV charger readiness, renovations, appliances, and safer power distribution.", link: "View panel service", icon: "M5 4h14v18H5z M9 8h6 M9 12h2 M13 12h2" },
    { title: "Brampton Electrician", href: "brampton-electrician.html", text: "Main electrical service page for repairs, upgrades, EV chargers, lighting, wiring, and troubleshooting.", link: "View electrician page", icon: "M4 12h4l2-6 4 12 2-6h4" },
    { title: "Emergency Electrician", href: "emergency-electrician.html", text: "Help for breaker trips, burning smells, power loss, sparks, and unsafe electrical symptoms.", link: "View emergency service", icon: "M13 2 5 14h6l-1 8 9-13h-6z" },
    { title: "Lighting & Smart Home", href: "lighting-smart-home.html", text: "Lighting installation, smart switches, controls, fixtures, and modern electrical upgrades.", link: "View lighting", icon: "M12 2a7 7 0 0 0-4 12c1 1 1 2 1 4h6c0-2 0-3 1-4a7 7 0 0 0-4-12z" },
  ]}
  photoEyebrow="Home charging setup"
  photoHeading="EV charging that fits daily use"
  photoText="A good charger location should make charging simple: close enough for cable reach, mounted cleanly, and planned with the electrical panel in mind."
  photoItems={["Level 2 charger circuit planning", "Garage and driveway charging options", "Panel check before installation"]}
  photoImage="https://images.unsplash.com/photo-1617886322207-6f504e7472c5?auto=format&fit=crop&w=1400&q=80"
  photoAlt="Electric vehicle charging cable connected for home charging"
  proofHeading="EV charger installation with a clear electrical path"
  proofText="Fateh helps Brampton EV owners plan charger placement, panel readiness, breaker sizing, wiring route, and daily charging convenience."
  proofCards={[
    { title: "Home charging focus", text: "Designed around where you park and how you charge." },
    { title: "Panel-aware service", text: "Existing electrical capacity is reviewed before the charger is added." },
    { title: "Future friendly", text: "Charging setup can support daily EV use and cleaner home electrical planning." },
  ]}
  processHeading="From charger plan to home charging"
  processSteps={[
    { title: "Share charger details", text: "Tell us the EV model, charger type, panel location, and where the vehicle parks." },
    { title: "Check the panel", text: "The electrician reviews capacity, breaker options, and the likely wiring route." },
    { title: "Install the circuit", text: "The dedicated circuit, wiring, and charger mounting are completed based on the approved plan." },
    { title: "Test charging", text: "The charger setup is checked so you understand how to use it safely." },
  ]}
  areaText="If you need a Level 2 EV charger, Tesla charger, garage charger, outdoor charging setup, or panel readiness check, tell us your Brampton neighbourhood and charger details."
  ctaEyebrow="Book EV charger installation"
  ctaHeading="Ready to install a Level 2 EV charger at home?"
  ctaText="Call Fateh Plumbing & Electric for EV charger installation in Brampton, including dedicated circuits, panel checks, breaker planning, and clean charger placement."
  faqEyebrow="EV charger FAQ"
  faqHeading="Common questions about EV charger installation in Brampton"
  faqs={faqs.map(([question, answer]) => ({ question, answer }))}
/>
