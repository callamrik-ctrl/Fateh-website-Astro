---
import ElectricalServicePage from "../components/ElectricalServicePage.astro";

const title = "Lighting Installation Brampton | Pot Lights, Fixtures & Smart Switches";
const description = "Lighting installation Brampton service for pot lights, fixtures, dimmers, smart switches, exterior lighting, under-cabinet lights, and smart home electrical setup.";
const canonical = "https://fatehplumelec.com/lighting-smart-home.html";

const faqs = [
  ["Do you provide lighting installation in Brampton?", "Yes. Fateh Plumbing & Electric helps with pot lights, fixture replacement, dimmers, switches, exterior lighting, under-cabinet lights, and smart lighting setup in Brampton."],
  ["Can you install pot lights?", "Yes. Pot light installation can be planned around ceiling access, room layout, switch controls, dimming needs, and the look you want in the space."],
  ["Do you install smart switches and dimmers?", "Yes. Fateh helps with smart switches, dimmers, lighting controls, and connected devices when the wiring and device requirements match the home setup."],
  ["Can you replace old light fixtures?", "Yes. Fixture replacement can include ceiling lights, vanity lights, dining lights, exterior fixtures, garage lights, and other common home lighting upgrades."],
  ["Why do my lights flicker?", "Flickering lights can be caused by a loose connection, bad fixture, overloaded circuit, dimmer compatibility issue, or panel concern. If flickering is frequent or paired with buzzing, call for service."],
  ["Can lighting work require a new circuit?", "Sometimes. Larger lighting upgrades, exterior lighting, additions, and smart home changes may need wiring review, switch changes, or a dedicated circuit."],
  ["Which Brampton areas do you serve?", "Fateh serves Brampton areas including Bramalea, Springdale, Castlemore, Mount Pleasant, Heart Lake, Fletcher's Meadow, Credit Valley, Peel Village, Downtown Brampton, and nearby communities."],
];

const schema = {
  "@context": "https://schema.org",
  "@type": "Electrician",
  name: "Fateh Plumbing & Electric",
  url: canonical,
  telephone: "647-980-9211",
  email: "info@fatehplumelec.com",
  image: "https://fatehplumelec.com/assets/fateh-logo-clean.png",
  logo: "https://fatehplumelec.com/assets/fateh-logo-clean.png",
  priceRange: "$$",
  address: { "@type": "PostalAddress", addressLocality: "Brampton", addressRegion: "ON", addressCountry: "CA" },
  areaServed: ["Brampton", "Bramalea", "Springdale", "Castlemore", "Mount Pleasant", "Mississauga", "Vaughan", "Caledon", "Etobicoke"],
  openingHoursSpecification: [{ "@type": "OpeningHoursSpecification", dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"], opens: "00:00", closes: "23:59" }],
  sameAs: ["https://www.facebook.com/fatehplumbing", "https://www.instagram.com/fateh_plumbing_electric"],
  serviceType: ["Lighting installation", "Pot light installation", "Smart switch installation", "Dimmer installation", "Exterior lighting", "Fixture replacement"],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map(([question, answer]) => ({ "@type": "Question", name: question, acceptedAnswer: { "@type": "Answer", text: answer } })),
};
---

<ElectricalServicePage
  title={title}
  description={description}
  canonical={canonical}
  schema={schema}
  faqSchema={faqSchema}
  eyebrow="Lighting installation • Pot lights • Smart switches"
  h1="Lighting Installation Brampton"
  intro="Need pot lights, fixture replacement, dimmers, smart switches, or exterior lighting? Fateh Plumbing & Electric helps Brampton customers with lighting installation and smart home electrical setup that looks clean and works properly."
  heroImage="https://images.unsplash.com/photo-1565079574649-1d9c7809856c?auto=format&fit=crop&w=1400&q=80"
  heroAlt="Modern recessed lighting and fixture installation in a finished room"
  proof={["Pot lights", "Smart switches", "Fixture replacement"]}
  trust={[
    { title: "Lighting layout", text: "Plan pot lights, fixtures, switches, dimmers, and controls.", icon: "M12 2a7 7 0 0 0-4 12c1 1 1 2 1 4h6c0-2 0-3 1-4a7 7 0 0 0-4-12z" },
    { title: "Smart controls", text: "Support for smart switches, dimmers, and connected lighting.", icon: "M4 6h16v12H4z M8 10h8 M8 14h5" },
    { title: "Clean installation", text: "Fixture replacement and wiring planned around the space.", icon: "M4 5h16v14H4z M8 9h5 M8 13h8 M17 7l2 2 3-4" },
  ]}
  introHeading="Lighting upgrades that improve how the space looks and works"
  introParagraphs={[
    "Lighting changes can completely change a room, but the electrical planning matters: fixture location, switch controls, dimming, circuit capacity, ceiling access, and smart device compatibility all affect the final result.",
    "Fateh Plumbing & Electric helps with pot light installation, fixture replacement, smart switches, dimmers, exterior lighting, under-cabinet lighting, and practical lighting repairs in Brampton homes and businesses.",
    "When you call, tell us which room or exterior area you want to improve, whether wiring already exists, what fixture or device you have, and whether you want dimming or smart controls.",
  ]}
  bookingTitle="Book lighting service"
  bookingText="Tell us the room, fixture type, switch location, dimmer needs, smart device plan, and whether new wiring may be needed."
  bookingItems={["Pot lights and recessed lighting", "Fixture replacement and dimmers", "Smart switches and lighting controls"]}
  problemEyebrow="Lighting and smart home needs"
  problemHeading="Choose the lighting issue or upgrade you need"
  problems={[
    { title: "Pot lights", text: "Recessed lighting can brighten kitchens, basements, living rooms, hallways, and offices.", href: "tel:+16479809211", link: "Book pot lights" },
    { title: "Fixture replacement", text: "Replace old, damaged, buzzing, or outdated fixtures with cleaner lighting.", href: "tel:+16479809211", link: "Call Fateh" },
    { title: "Smart switches", text: "Smart switches and dimmers need compatible wiring, device setup, and practical placement.", href: "electrical-services.html", link: "Smart switch help" },
    { title: "Exterior lighting", text: "Outdoor fixtures, security lighting, garage lighting, and entry lighting need weather-aware planning.", href: "tel:+16479809211", link: "Outdoor lighting" },
    { title: "Lights flicker or buzz", text: "Flickering or buzzing can point to fixture, dimmer, wiring, or circuit concerns.", href: "emergency-electrician.html", link: "Electrical help" },
    { title: "Under-cabinet lights", text: "Kitchen and workspace lighting can be planned around counters, cabinets, and switches.", href: "tel:+16479809211", link: "Book lighting" },
  ]}
  safetyHeading="What makes lighting installation go smoothly"
  safetyParagraphs={[
    "Good lighting work starts with how the space is used. A kitchen, basement, hallway, bathroom, exterior entry, and garage all need different brightness, placement, and controls.",
    "If existing lights flicker, buzz, trip a breaker, or feel hot, the issue should be checked before adding new fixtures or smart controls. Compatibility matters with dimmers and smart switches.",
  ]}
  safetyItems={["Room or exterior area", "Existing fixture or new location", "Pot light count if known", "Dimmer or smart switch preference", "Flickering, buzzing, or breaker concerns"]}
  relatedServices={[
    { title: "Brampton Electrician", href: "brampton-electrician.html", text: "Main electrical service page for lighting, wiring, repairs, panel work, EV chargers, and troubleshooting.", link: "View electrician page", icon: "M4 12h4l2-6 4 12 2-6h4" },
    { title: "Emergency Electrician", href: "emergency-electrician.html", text: "Help for sparks, burning smells, repeated breaker trips, buzzing, and unsafe electrical symptoms.", link: "View emergency service", icon: "M13 2 5 14h6l-1 8 9-13h-6z" },
    { title: "Panel Upgrade", href: "panel-upgrade.html", text: "Capacity planning for renovations, lighting upgrades, appliances, EV chargers, and safer circuits.", link: "View panel service", icon: "M5 4h14v18H5z M9 8h6 M9 12h2 M13 12h2" },
    { title: "EV Charger Installation", href: "ev-charger-installation.html", text: "Level 2 home charger installation, dedicated circuits, breaker planning, and charger placement.", link: "View EV chargers", icon: "M7 2v8 M17 2v8 M5 10h14 M8 22h8" },
  ]}
  photoEyebrow="Lighting and control upgrades"
  photoHeading="Cleaner lighting for kitchens, basements, entries, and work areas"
  photoText="Lighting installation should feel balanced, practical, and easy to control. Fateh helps plan fixtures, switches, dimmers, smart controls, and wiring around the way the space is used."
  photoItems={["Pot lights and fixture replacement", "Smart switches, dimmers, and controls", "Interior and exterior lighting support"]}
  photoImage="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=1400&q=80"
  photoAlt="Modern home room with warm lighting and fixtures"
  proofHeading="Lighting service that fits the space"
  proofText="Fateh helps Brampton customers choose practical lighting, switch, dimmer, and smart control options for homes, rentals, offices, restaurants, and small businesses."
  proofCards={[
    { title: "Room-by-room planning", text: "Lighting is planned around how the space is used and controlled." },
    { title: "Smart device support", text: "Switches, dimmers, and controls are reviewed for compatibility." },
    { title: "Repair plus install", text: "We can help with upgrades and lighting problems like flicker or buzzing." },
  ]}
  processHeading="From lighting idea to finished install"
  processSteps={[
    { title: "Describe the space", text: "Tell us the room, fixture, switch setup, lighting goal, and any smart control needs." },
    { title: "Review wiring", text: "The electrician checks existing wiring, switch location, dimmer compatibility, and circuit concerns." },
    { title: "Install lighting", text: "Fixtures, pot lights, switches, dimmers, or controls are installed based on the plan." },
    { title: "Test controls", text: "The lighting is checked so you know how the switches, dimmers, or smart controls work." },
  ]}
  areaText="If you need pot lights, fixture replacement, dimmers, smart switches, exterior lighting, or under-cabinet lighting, tell us your Brampton neighbourhood and the room or area involved."
  ctaEyebrow="Book lighting installation"
  ctaHeading="Planning pot lights, fixture replacement, or smart switches?"
  ctaText="Call Fateh Plumbing & Electric for lighting installation in Brampton, including pot lights, dimmers, smart switches, exterior fixtures, and lighting repairs."
  faqEyebrow="Lighting FAQ"
  faqHeading="Common questions about lighting installation in Brampton"
  faqs={faqs.map(([question, answer]) => ({ question, answer }))}
/>
