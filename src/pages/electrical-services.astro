---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

const title = "Electrical Services in Brampton | Licensed Electrician & Emergency Repairs";
const description = "Fateh Plumbing & Electric provides electrical services in Brampton, including emergency repair, panels, EV chargers, generators, subpanels, surge protection, pot lights, ceiling fans, smart wiring, and outdoor lighting.";
const canonical = "https://fatehplumelec.com/electrical-services.html";

const electricalServices = [
  {
    title: "Emergency Electrician",
    href: "emergency-electrician.html",
    text: "Urgent help for power issues, sparking outlets, breaker problems, burning smells, and unsafe electrical symptoms.",
    icon: "M13 2 4 14h7l-1 8 10-12h-7z M4 4l2 2 M20 4l-2 2",
  },
  {
    title: "Electrical Panel Upgrade",
    href: "panel-upgrade.html",
    text: "Panel capacity planning for 100A to 200A upgrades, breaker concerns, renovations, EV chargers, and safer distribution.",
    icon: "M5 3h14v18H5z M9 8h2 M13 8h2 M9 12h2 M13 12h2 M9 16h6",
  },
  {
    title: "EV Charger Installation",
    href: "ev-charger-installation.html",
    text: "Level 2 home charger installation with dedicated circuit planning, panel checks, garage charging, and clean placement.",
    icon: "M6 19h10a3 3 0 0 0 3-3v-2 M5 11h8l-1 8H6z M8 11V6a2 2 0 0 1 4 0v5 M19 7v4 M17 7h4",
  },
  {
    title: "Generator Installation Services",
    href: "generator-installation.html",
    text: "Backup power planning, property assessment, safe electrical connection review, installation support, testing, and customer explanation.",
    icon: "M4 15h16v5H4z M7 15V9a5 5 0 0 1 10 0v6 M9 20v2 M15 20v2 M10 11h4",
  },
  {
    title: "Electrical Subpanel Installation",
    href: "subpanel-installation.html",
    text: "Additional circuit planning for basements, garages, workshops, additions, equipment areas, and organized power distribution.",
    icon: "M6 4v16 M6 8h8a4 4 0 0 1 0 8H6 M14 8h4 M14 16h4",
  },
  {
    title: "Whole-Home Surge Protection",
    href: "surge-protection.html",
    text: "Panel-based surge protection installation to help reduce risk from certain electrical surges affecting appliances and electronics.",
    icon: "M12 3 5 6v6c0 4.5 3 7.5 7 9 4-1.5 7-4.5 7-9V6z M9 12l2 2 4-5",
  },
  {
    title: "Pot Light Installation",
    href: "pot-light-installation.html",
    text: "Indoor recessed lighting and outdoor soffit pot lights with layout planning, fixture spacing, wiring assessment, testing, and review.",
    icon: "M9 18h6 M10 22h4 M8 10a4 4 0 1 1 8 0c0 2-1.3 3.1-2.1 4.2-.4.5-.6 1.1-.6 1.8h-2.6c0-.7-.2-1.3-.6-1.8C9.3 13.1 8 12 8 10z",
  },
  {
    title: "Ceiling Fan Installation",
    href: "ceiling-fan-installation.html",
    text: "New ceiling fan installation and fan replacement with wiring assessment, support review, controls, testing, and final walkthrough.",
    icon: "M12 11a2 2 0 1 0 0 4 2 2 0 0 0 0-4z M12 11c-1-4 1-7 4-7 2 0 3 1 3 3 0 3-3 4-7 4z M12 13c4-1 7 1 7 4 0 2-1 3-3 3-3 0-4-3-4-7z",
  },
  {
    title: "Smart Home Wiring",
    href: "smart-home-wiring.html",
    text: "Smart switches, dimmers, motion sensors, timers, compatible lighting controls, speaker wiring, and wiring preparation.",
    icon: "M4 12h4l2-6 4 12 2-6h4 M5 20h14 M7 4h10",
  },
  {
    title: "Outdoor Lighting",
    href: "outdoor-lighting.html",
    text: "Exterior lighting for porches, entrances, security areas, motion sensors, garages, patios, pathways, and suitable soffit lighting.",
    icon: "M4 20h16 M6 20v-8l6-5 6 5v8 M9 20v-5h6v5 M8 7l4-3 4 3",
  },
  {
    title: "Lighting & Smart Home",
    href: "lighting-smart-home.html",
    text: "Lighting installation and smart home electrical setup, including pot lights, fixtures, switches, controls, and device planning.",
    icon: "M9 18h6 M10 22h4 M8 10a4 4 0 1 1 8 0c0 2-1.3 3.1-2.1 4.2-.4.5-.6 1.1-.6 1.8h-2.6c0-.7-.2-1.3-.6-1.8C9.3 13.1 8 12 8 10z",
  },
];

const faqs = [
  ["Do you provide electrical services in Brampton?", "Fateh Plumbing & Electric provides electrical services in Brampton and nearby GTA communities. Call to describe the issue, confirm availability, and choose the next step."],
  ["Can I get same-day electrical service?", "Same-day service depends on schedule, location, and urgency. Unsafe wiring, sparking outlets, burning smells, and power issues are treated as priority calls."],
  ["How do I know if I need an electrician right away?", "Call right away for sparking, burning smells, repeated breaker trips, partial power loss, exposed wiring, or any electrical issue that feels unsafe."],
  ["Do you handle planned electrical installations?", "Yes. Fateh helps with panel upgrades, EV charger installation, generator installation planning, subpanel installation, surge protection, lighting, and smart home electrical work."],
];

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "Electrician",
    name: "Fateh Plumbing & Electric",
    url: canonical,
    telephone: "647-980-9211",
    email: "info@fatehplumelec.com",
    image: "https://fatehplumelec.com/assets/fateh-logo-clean.png",
    logo: "https://fatehplumelec.com/assets/fateh-logo-clean.png",
    priceRange: "$$",
    address: { "@type": "PostalAddress", addressLocality: "Brampton", addressRegion: "ON", addressCountry: "CA" },
    areaServed: ["Brampton", "Mississauga", "Vaughan", "Caledon", "Etobicoke", "Greater Toronto Area"],
    serviceType: electricalServices.map((service) => service.title),
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map(([question, answer]) => ({ "@type": "Question", name: question, acceptedAnswer: { "@type": "Answer", text: answer } })),
  },
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
  {schemas.map((schema) => <script type="application/ld+json" set:html={JSON.stringify(schema)} />)}
  <SiteHeader current="electrical" />

  <main class="page-hero">
    <div>
      <p class="eyebrow">All electrical services</p>
      <h1>Electrical services in Brampton</h1>
      <p>Fateh Plumbing & Electric helps Brampton homeowners and businesses with emergency electrical repair, panel upgrades, EV charger installation, generator installation, subpanels, surge protection, pot light installation, ceiling fan installation, smart home wiring, outdoor lighting, breaker issues, outlets, switches, and electrical troubleshooting.</p>
      <div class="hero-actions">
        <a class="button" href="tel:+16479809211">Call 647-980-9211</a>
        <a class="button secondary" href="contact.html">Request service</a>
      </div>
    </div>
    <img class="page-hero-photo" src="https://images.unsplash.com/photo-1621905251189-08b45d6a269e?auto=format&fit=crop&w=1400&q=80" alt="Electrician working on residential electrical wiring" width="700" height="460">
  </main>

  <section class="band">
    <div class="section-heading">
      <p class="eyebrow">Electrical service options</p>
      <h2>Choose the electrical help that matches the problem</h2>
    </div>
    <div class="card-grid">
      {electricalServices.map((service) => (
        <article class="service-card electrical-card">
          <div class="service-card-body">
            <div class="card-head">
              <span class="card-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false"><path d={service.icon}></path></svg>
              </span>
              <div>
                <p class="card-kicker">Electrical</p>
                <h3><a href={service.href}>{service.title}</a></h3>
              </div>
            </div>
            <p>{service.text}</p>
            <a class="text-link" href={service.href}>Learn more</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="content">
    <div>
      <h2>Planned upgrades, urgent repairs, and safer electrical next steps</h2>
      <p>Electrical calls can be urgent, planned, or part of a larger renovation. Burning smells, sparking outlets, repeated breaker trips, partial power loss, and exposed wiring should be treated carefully and checked by a qualified electrician.</p>
      <p>If you are planning an upgrade, Fateh can help with <a href="panel-upgrade.html">electrical panel upgrades</a>, <a href="ev-charger-installation.html">EV charger installation</a>, <a href="generator-installation.html">generator installation services</a>, <a href="subpanel-installation.html">electrical subpanel installation</a>, <a href="surge-protection.html">whole-home surge protection</a>, <a href="pot-light-installation.html">pot light installation</a>, <a href="ceiling-fan-installation.html">ceiling fan installation</a>, <a href="smart-home-wiring.html">smart home wiring</a>, <a href="outdoor-lighting.html">outdoor lighting</a>, or <a href="emergency-electrician.html">emergency electrical service</a>.</p>
    </div>
    <aside class="quick-card">
      <p class="eyebrow">Need help?</p>
      <h2>Call Fateh</h2>
      <p>Tell us what is happening, what you want installed, and whether the issue feels urgent.</p>
      <a class="button" href="tel:+16479809211">Call 647-980-9211</a>
      <a class="button secondary" href="contact.html">Request service online</a>
    </aside>
  </section>

  <section class="band">
    <div class="section-heading">
      <p class="eyebrow">Related electrical services</p>
      <h2>Keep moving through the right service path</h2>
    </div>
    <div class="link-grid">
      {electricalServices.slice(1).map((service) => (
        <a href={service.href}>
          <span class="link-card-head">
            <span class="card-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false"><path d={service.icon}></path></svg>
            </span>
            <strong>{service.title}</strong>
          </span>
          <span>{service.text}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="band faq">
    <div class="section-heading">
      <p class="eyebrow">Electrical FAQ</p>
      <h2>Common questions about electrical services in Brampton</h2>
    </div>
    {faqs.map(([question, answer]) => <details><summary>{question}</summary><p>{answer}</p></details>)}
  </section>

  <SiteFooter />
</BaseLayout>
