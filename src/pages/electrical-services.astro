---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

const title = "Electrical Services Brampton | Fateh";
const description = "Electrical services Brampton and GTA for panels, repairs, EV chargers, lighting, and safety checks. Free on-site assessment.";
const canonical = "https://fatehplumelec.com/electrical-services.html";
const phone = "647-980-9211";
const siteUrl = "https://fatehplumelec.com";

const icons = {
  panel: "M5 4h14v18H5z M9 8h6 M9 12h2 M13 12h2 M9 16h2 M13 16h2",
  bolt: "M13 2 5 14h6l-1 8 9-13h-6z",
  shield: "M12 3 5 6v6c0 4.5 3 7.5 7 9 4-1.5 7-4.5 7-9V6z",
  home: "M3 11 12 4l9 7v9H5v-9z M9 20v-6h6v6",
  branch: "M6 4v16 M6 8h8a4 4 0 0 1 0 8H6",
  light: "M9 18h6 M10 22h4 M8 10a4 4 0 1 1 8 0c0 2-1.3 3.1-2.1 4.2-.4.5-.6 1.1-.6 1.8h-2.6c0-.7-.2-1.3-.6-1.8C9.3 13.1 8 12 8 10z",
  fan: "M12 11a2 2 0 1 0 0 4 2 2 0 0 0 0-4z M12 11c-1-4 1-7 4-7 2 0 3 1 3 3 0 3-3 4-7 4z M12 13c4-1 7 1 7 4 0 2-1 3-3 3-3 0-4-3-4-7z",
  smart: "M4 12h4l2-6 4 12 2-6h4 M5 20h14 M7 4h10",
  outdoor: "M4 20h16 M6 20v-8l6-5 6 5v8 M9 20v-5h6v5 M8 7l4-3 4 3",
};

const serviceGroups = [
  {
    title: "Panels & Power",
    text: "Plan safer capacity for added loads, backup power, EV charging, and modern electrical use.",
    icon: icons.panel,
    services: [
      { title: "Electrical Panel Upgrade", href: "panel-upgrade.html", text: "Panel capacity planning for renovations, EV chargers, breaker concerns, and added circuits." },
      { title: "EV Charger Installation", href: "ev-charger-installation.html", text: "Level 2 charger wiring, breaker sizing, garage placement, and panel readiness review." },
      { title: "Generator Installation", href: "generator-installation.html", text: "Backup power planning, panel readiness, generator connection review, and testing." },
      { title: "Subpanel Installation", href: "subpanel-installation.html", text: "Subpanel planning for garages, basements, workshops, additions, and equipment areas." },
      { title: "Surge Protection", href: "surge-protection.html", text: "Panel-based surge protection planning for appliances, electronics, and sensitive equipment." },
    ],
  },
  {
    title: "Wiring & Repair",
    text: "Troubleshoot electrical problems and plan wiring updates for rooms, renovations, and older homes.",
    icon: icons.branch,
    services: [
      { title: "Electrical Repair", href: "electrical-repair.html", text: "Troubleshooting for outlets, switches, breakers, lights, partial power, and unsafe symptoms." },
      { title: "House Rewiring", href: "house-rewiring.html", text: "Wiring updates for older homes, renovations, additions, outlets, lights, and circuits." },
      { title: "Outlet & Switch Install", href: "outlet-switch-install.html", text: "Outlet, switch, dimmer, timer, smart control, and device installation review." },
      { title: "New Construction Electrician", href: "new-construction-electrician.html", text: "Electrical rough-in planning for new builds, additions, garages, basements, and renovations." },
    ],
  },
  {
    title: "Lighting & Smart Home",
    text: "Improve lighting, controls, exterior visibility, and smart electrical convenience around the property.",
    icon: icons.light,
    services: [
      { title: "Pot Light Installation", href: "pot-light-installation.html", text: "Recessed lighting plans for kitchens, basements, living rooms, work areas, and soffits." },
      { title: "Ceiling Fan Installation", href: "ceiling-fan-installation.html", text: "Fan wiring, replacement, support review, switch controls, and testing." },
      { title: "Smart Home Wiring", href: "smart-home-wiring.html", text: "Smart switches, dimmers, timers, sensors, low-voltage planning, and compatible controls." },
      { title: "Outdoor Lighting", href: "outdoor-lighting.html", text: "Exterior lighting for porches, entrances, garages, patios, pathways, and security areas." },
      { title: "Driveway Lighting", href: "driveway-lighting.html", text: "Driveway, garage approach, pathway, and motion lighting for outdoor visibility." },
    ],
  },
  {
    title: "Emergency & Safety",
    text: "Get urgent electrical help and review safety items before they become bigger problems.",
    icon: icons.shield,
    services: [
      { title: "Emergency Electrician", href: "emergency-electrician.html", text: "Urgent help for sparks, burning smell, repeated breaker trips, and partial power loss." },
      { title: "Electrical Safety Inspection", href: "electrical-safety-inspection.html", text: "Safety review for panels, breakers, outlets, switches, wiring concerns, and older homes." },
      { title: "Smoke & CO Detectors", href: "smoke-co-detectors.html", text: "Smoke alarm and carbon monoxide detector installation or replacement review." },
    ],
  },
];

const allServices = serviceGroups.flatMap((group) => group.services);
const featureItems = [
  { title: "Emergency troubleshooting", text: "Help for sparks, burning smells, repeated breaker trips, partial power, and urgent safety concerns.", icon: icons.bolt },
  { title: "Panel and power upgrades", text: "Planning for panels, subpanels, generators, surge protection, and EV charger readiness.", icon: icons.panel },
  { title: "Lighting and controls", text: "Pot lights, ceiling fans, smart switches, outdoor lighting, driveway lighting, and fixture updates.", icon: icons.light },
  { title: "Wiring and safety", text: "Support for repairs, rewiring, new construction rough-ins, safety inspections, and detectors.", icon: icons.shield },
];

const featuredServices = [
  allServices.find((service) => service.href === "emergency-electrician.html"),
  allServices.find((service) => service.href === "panel-upgrade.html"),
  allServices.find((service) => service.href === "ev-charger-installation.html"),
  allServices.find((service) => service.href === "electrical-repair.html"),
  allServices.find((service) => service.href === "pot-light-installation.html"),
  allServices.find((service) => service.href === "house-rewiring.html"),
  allServices.find((service) => service.href === "electrical-safety-inspection.html"),
  allServices.find((service) => service.href === "new-construction-electrician.html"),
].filter(Boolean);

const viewLabel = (title) => {
  const label = title
    .replace(/^Electrical\s+/i, "")
    .replace(/\s+Installation$/i, "")
    .replace(/\s+Install$/i, "")
    .toLowerCase();
  return `View ${label} service`;
};

const faqs = [
  ["What electrical services do you provide?", "Fateh Plumbing & Electric helps with electrical repair, panel upgrades, EV charger installation, generator planning, subpanels, surge protection, lighting, wiring, safety inspections, and detector installation."],
  ["Do you provide residential electrical services in Brampton?", "Yes. Fateh provides residential electrical services in Brampton and nearby GTA areas for repairs, upgrades, installations, wiring, lighting, and safety concerns."],
  ["When should I call an electrician right away?", "Call right away for sparks, burning smell, smoke, hot outlets, buzzing panels, repeated breaker trips, exposed wiring, partial power loss, or any electrical issue that feels unsafe."],
  ["Can you help with planned electrical upgrades?", "Yes. Planned work can include panel upgrades, EV chargers, subpanels, generators, pot lights, ceiling fans, smart controls, outdoor lighting, and wiring for renovations."],
  ["How should I prepare before calling?", "Tell us what is happening, which room or area is affected, whether a breaker trips, what you want installed, and whether there are urgent symptoms such as heat, smell, buzzing, or sparks."],
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Electrician",
      "@id": `${siteUrl}/#electrician`,
      name: "Fateh Plumbing & Electric",
      url: siteUrl,
      telephone: phone,
      email: "info@fatehplumelec.com",
      image: `${siteUrl}/assets/fateh-logo-clean.png`,
      logo: `${siteUrl}/assets/fateh-logo-clean.png`,
      priceRange: "$$",
      address: { "@type": "PostalAddress", addressLocality: "Brampton", addressRegion: "ON", addressCountry: "CA" },
      areaServed: ["Brampton", "Mississauga", "Vaughan", "Caledon", "Etobicoke", "Greater Toronto Area"],
    },
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      url: canonical,
      name: title,
      description,
      isPartOf: { "@id": `${siteUrl}/#website` },
      about: { "@id": `${canonical}#service` },
    },
    {
      "@type": "Service",
      "@id": `${canonical}#service`,
      name: "Electrical Services",
      description: "Electrical services for repairs, panel upgrades, EV chargers, lighting, wiring, generators, safety inspections, smoke and CO detectors, and residential electrical service in Brampton and nearby GTA areas.",
      serviceType: allServices.map((service) => service.title),
      provider: { "@id": `${siteUrl}/#electrician` },
      areaServed: ["Brampton", "Mississauga", "Vaughan", "Caledon", "Etobicoke", "Greater Toronto Area"],
      url: canonical,
      hasOfferCatalog: {
        "@type": "OfferCatalog",
        name: "Electrical service options",
        itemListElement: serviceGroups.map((group) => ({
          "@type": "OfferCatalog",
          name: group.title,
          itemListElement: group.services.map((service) => ({
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: service.title,
              url: `${siteUrl}/${service.href}`,
              description: service.text,
            },
          })),
        })),
      },
    },
    {
      "@type": "FAQPage",
      "@id": `${canonical}#faq`,
      mainEntity: faqs.map(([question, answer]) => ({
        "@type": "Question",
        name: question,
        acceptedAnswer: { "@type": "Answer", text: answer },
      })),
    },
  ],
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <SiteHeader current="electrical" />

  <main class="page-hero electrical-page-hero electrical-services-hero">
    <div>
      <p class="eyebrow">Residential electrical services - Brampton & nearby GTA</p>
      <h1>Electrical Services in Brampton</h1>
      <p>Fateh Plumbing & Electric helps homeowners, rental units, small businesses, and managed properties with electrical repair, panel upgrades, EV charger installation, lighting, wiring services, generators, safety inspections, and urgent electrical concerns.</p>
      <div class="hero-actions">
        <a class="button" href="tel:+16479809211">Call 647-980-9211</a>
        <a class="button secondary" href="contact.html">Request electrical service</a>
      </div>
    </div>
    <div class="hero-service-card">
      <img src="https://images.unsplash.com/photo-1621905251189-08b45d6a269e?auto=format&fit=crop&w=1400&q=80" alt="Electrician working on residential electrical panel wiring" width="760" height="520">
    </div>
  </main>

  <section class="electrical-hub-feature-strip" aria-label="Electrical service highlights">
    {featureItems.map((item) => (
      <article>
        <span class="hub-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d={item.icon}></path></svg>
        </span>
        <div>
          <h2>{item.title}</h2>
          <p>{item.text}</p>
        </div>
      </article>
    ))}
  </section>

  <section class="band service-hub-band electrical-hub-band electrical-services-category-band">
    <div class="section-heading">
      <p class="eyebrow">Electrical service menu</p>
      <h2>Choose the right electrical service category</h2>
    </div>
    <div class="electrical-category-grid">
      {serviceGroups.map((group) => (
        <article class="electrical-category-card">
          <div class="category-head">
            <span class="hub-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d={group.icon}></path></svg>
            </span>
            <div>
              <h3>{group.title}</h3>
              <p>{group.text}</p>
            </div>
          </div>
          <ul>
            {group.services.map((service) => (
              <li>
                <a href={service.href}>{service.title}</a>
                <span>{service.text}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="content electrical-content-section electrical-hub-intro">
    <div class="electrical-copy">
      <p class="eyebrow">Electrical help without confusion</p>
      <h2>One local hub for repairs, upgrades, and installations</h2>
      <p>Electrical service can be urgent, planned, or part of a larger renovation. The right next step depends on the symptom, the affected area, the panel condition, and what you want the system to support.</p>
      <p>If you have sparks, a burning smell, partial power, repeated breaker trips, or an outlet that feels hot, avoid using the affected circuit and call for help. For planned work, start with the service category above or request a visit so the setup can be reviewed properly.</p>
      <div class="electrical-inline-panel">
        <h3>Common reasons customers call</h3>
        <ul>
          <li>Breaker trips, outlet issues, or partial power</li>
          <li>Panel, subpanel, generator, or EV charger planning</li>
          <li>Pot lights, ceiling fans, smart switches, and exterior lighting</li>
          <li>Older wiring, renovations, safety inspections, or detectors</li>
        </ul>
      </div>
    </div>
    <aside class="quick-card booking-card">
      <p class="eyebrow">Need help?</p>
      <h2>Book electrical service</h2>
      <p>Tell us what is happening, what you want installed, and whether the issue feels urgent.</p>
      <a class="button" href="tel:+16479809211">Call 647-980-9211</a>
      <a class="button secondary" href="contact.html">Request service online</a>
    </aside>
  </section>

  <section class="band problem-band electrical-problem-band">
    <div class="section-heading">
      <p class="eyebrow">Common electrical services</p>
      <h2>Frequently requested electrical help</h2>
    </div>
    <div class="service-hub-grid">
      {featuredServices.map((service) => (
        <article>
          <span class="hub-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d={icons.bolt}></path></svg>
          </span>
          <h3><a href={service.href}>{service.title}</a></h3>
          <p>{service.text}</p>
          <a class="text-link" href={service.href}>{viewLabel(service.title)}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="electrical-dark-band" aria-label="Electrical service overview">
    <div>
      <p class="eyebrow">Electrical service hub</p>
      <h2>Repairs, power planning, lighting, and safety in one place</h2>
      <p>Fateh Plumbing & Electric helps customers across Brampton and nearby GTA areas choose the right electrical path, from urgent repairs and safety inspections to panel planning, EV chargers, wiring updates, lighting, detectors, and new construction electrical needs.</p>
    </div>
    <a class="button" href="contact.html">Request electrical service</a>
  </section>

  <section class="band process-band electrical-process-band">
    <div class="section-heading">
      <p class="eyebrow">How service works</p>
      <h2>From first call to clear next step</h2>
    </div>
    <div class="process-steps">
      <article><span>1</span><h3>Describe the issue</h3><p>Tell us what happened, what needs to be installed, and whether anything feels unsafe.</p></article>
      <article><span>2</span><h3>Review the property</h3><p>The affected area, circuit, panel, wiring route, fixture, or device is reviewed based on the service.</p></article>
      <article><span>3</span><h3>Explain the option</h3><p>You get a practical next step for repair, replacement, upgrade, installation, or further planning.</p></article>
      <article><span>4</span><h3>Complete and test</h3><p>Completed work is checked and the service area is reviewed before the job is wrapped up.</p></article>
    </div>
  </section>

  <section class="content neighbourhood-section electrical-content-section electrical-area-section">
    <div class="electrical-copy">
      <p class="eyebrow">Service area</p>
      <h2>Electrician in Brampton and nearby GTA areas</h2>
      <p>Fateh Plumbing & Electric operates from Brampton, Ontario and helps customers across nearby GTA communities with residential electrical services, electrical repair, lighting installation, panel work, EV chargers, wiring services, and safety concerns.</p>
      <p>When you call, share your neighbourhood, the room or area involved, what you need installed or repaired, and whether there are urgent symptoms such as sparks, heat, buzzing, smell, or repeated breaker trips.</p>
      <div class="electrical-inline-panel compact">
        <h3>Helpful details to mention</h3>
        <ul>
          <li>Home, rental, small business, or managed property</li>
          <li>Repair, upgrade, installation, or inspection need</li>
          <li>Panel location and breaker symptoms if relevant</li>
          <li>Any urgent safety warning signs</li>
        </ul>
      </div>
    </div>
    <aside class="quick-card area-card">
      <h2>Areas we serve</h2>
      <div class="area-tags">
        {["Brampton", "Bramalea", "Springdale", "Castlemore", "Mount Pleasant", "Heart Lake", "Fletcher's Meadow", "Credit Valley", "Mississauga", "Vaughan", "Caledon", "Etobicoke"].map((area) => <span>{area}</span>)}
      </div>
    </aside>
  </section>

  <section class="band faq electrical-services-faq">
    <div class="section-heading">
      <p class="eyebrow">Electrical FAQ</p>
      <h2>Common questions about electrical services in Brampton</h2>
    </div>
    {faqs.map(([question, answer]) => <details><summary>{question}</summary><p>{answer}</p></details>)}
  </section>

  <section class="brampton-cta-band electrical-cta-band electrical-services-final-cta">
    <div>
      <p class="eyebrow">Electrical service</p>
      <h2>Need electrical repair, installation, or upgrade planning?</h2>
      <p>Call Fateh Plumbing & Electric for electrical services in Brampton, including panels, EV chargers, lighting, wiring, safety inspections, and urgent electrical concerns.</p>
    </div>
    <a class="button" href="tel:+16479809211">Call 647-980-9211</a>
  </section>

  <SiteFooter />
</BaseLayout>
