---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "./SiteHeader.astro";
import SiteFooter from "./SiteFooter.astro";

const {
  title,
  description,
  canonical,
  eyebrow,
  h1,
  heroText,
  heroImage,
  heroAlt,
  proof = [],
  trust = [],
  intro,
  quickCard,
  problems = [],
  process = [],
  compare,
  related = [],
  proofBand,
  faqs = [],
} = Astro.props;

const plumberSchema = {
  "@context": "https://schema.org",
  "@type": "Plumber",
  name: "Fateh Plumbing & Electric",
  url: canonical,
  telephone: "647-980-9211",
  email: "info@fatehplumelec.com",
  image: "https://fatehplumelec.com/assets/fateh-logo-clean.png",
  logo: "https://fatehplumelec.com/assets/fateh-logo-clean.png",
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Brampton",
    addressRegion: "ON",
    addressCountry: "CA",
  },
  areaServed: ["Brampton", "Bramalea", "Springdale", "Castlemore", "Mount Pleasant", "Heart Lake", "Mississauga", "Vaughan", "Caledon", "Etobicoke"],
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
      opens: "00:00",
      closes: "23:59",
    },
  ],
  sameAs: [
    "https://www.facebook.com/fatehplumbing",
    "https://www.instagram.com/fateh_plumbing_electric",
  ],
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: h1,
  serviceType: title.split("|")[0].trim(),
  provider: {
    "@type": "LocalBusiness",
    name: "Fateh Plumbing & Electric",
    telephone: "647-980-9211",
  },
  areaServed: {
    "@type": "City",
    name: "Brampton",
  },
  url: canonical,
  description,
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.a,
    },
  })),
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(plumberSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <SiteHeader />

  <main class="page-hero brampton-plumber-hero kitchen-service-hero">
    <div>
      <p class="eyebrow">{eyebrow}</p>
      <h1>{h1}</h1>
      <p>{heroText}</p>
      <div class="hero-actions">
        <a class="button" href="tel:+16479809211">Call 647-980-9211</a>
        <a class="button secondary" href="contact.html">Request service</a>
      </div>
      <div class="hero-proof-row" aria-label="Service highlights">
        {proof.map((item) => <span>{item}</span>)}
      </div>
    </div>
    <div class="hero-service-card">
      <img src={heroImage} alt={heroAlt} width="760" height="520">
    </div>
  </main>

  <section class="home-trust-banner plumber-trust-banner" aria-label="Service highlights">
    {trust.map((item) => (
      <article class="trust-feature">
        <span class="trust-feature-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M6 4v16"></path><path d="M18 4v16"></path><path d="M6 8h12"></path><path d="M6 16h12"></path></svg>
        </span>
        <div>
          <h2>{item.title}</h2>
          <p>{item.text}</p>
        </div>
      </article>
    ))}
  </section>

  <section class="content plumber-intro">
    <div>
      <p class="eyebrow">{intro.eyebrow}</p>
      <h2>{intro.title}</h2>
      {intro.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>
    <aside class="quick-card booking-card">
      <p class="eyebrow">{quickCard.eyebrow}</p>
      <h2>{quickCard.title}</h2>
      <p>{quickCard.text}</p>
      <a class="button" href="tel:+16479809211">Call 647-980-9211</a>
      <a class="button secondary" href="contact.html">Request service</a>
      <ul class="mini-links">
        {quickCard.points.map((point) => <li>{point}</li>)}
      </ul>
    </aside>
  </section>

  <section class="band problem-band">
    <div class="section-heading">
      <p class="eyebrow">{problems.eyebrow}</p>
      <h2>{problems.title}</h2>
    </div>
    <div class="problem-grid">
      {problems.items.map((item) => (
        <article>
          <strong>{item.title}</strong>
          <p>{item.text}</p>
          <a href={item.href}>{item.link}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="band process-band">
    <div class="section-heading">
      <p class="eyebrow">{process.eyebrow}</p>
      <h2>{process.title}</h2>
    </div>
    <div class="process-steps">
      {process.items.map((item, index) => (
        <article>
          <span>{index + 1}</span>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="content plumber-intro">
    <div>
      <p class="eyebrow">{compare.eyebrow}</p>
      <h2>{compare.title}</h2>
      {compare.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>
    <aside class="quick-card">
      <h2>{compare.cardTitle}</h2>
      <ul class="check-list">
        {compare.points.map((point) => <li>{point}</li>)}
      </ul>
    </aside>
  </section>

  <section class="band service-hub-band">
    <div class="section-heading">
      <p class="eyebrow">Related plumbing services</p>
      <h2>Kitchen and plumbing service paths</h2>
    </div>
    <div class="service-hub-grid">
      {related.map((item) => (
        <article>
          <span class="hub-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M4 12h16"></path><path d="M8 6v12"></path><path d="M16 6v12"></path><path d="M7 18h10"></path></svg>
          </span>
          <h3><a href={item.href}>{item.title}</a></h3>
          <p>{item.text}</p>
          <a class="text-link" href={item.href}>{item.link}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="proof-band">
    <div>
      <p class="eyebrow">{proofBand.eyebrow}</p>
      <h2>{proofBand.title}</h2>
      <p>{proofBand.text}</p>
    </div>
    <div class="proof-grid">
      {proofBand.items.map((item) => (
        <article>
          <strong>{item.title}</strong>
          <span>{item.text}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="brampton-cta-band">
    <div>
      <p class="eyebrow">Book service</p>
      <h2>Need help with kitchen plumbing in Brampton?</h2>
      <p>Call Fateh Plumbing & Electric for clear service, practical repair options, and kitchen plumbing help for homes, rentals, and small businesses.</p>
    </div>
    <a class="button" href="tel:+16479809211">Call 647-980-9211</a>
  </section>

  <section class="band faq">
    <div class="section-heading">
      <p class="eyebrow">FAQ</p>
      <h2>Common questions before booking service</h2>
    </div>
    {faqs.map((faq) => (
      <details>
        <summary>{faq.q}</summary>
        <p>{faq.a}</p>
      </details>
    ))}
  </section>

  <SiteFooter />
</BaseLayout>
