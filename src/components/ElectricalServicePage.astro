---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "./SiteHeader.astro";
import SiteFooter from "./SiteFooter.astro";

const {
  title,
  description,
  canonical,
  schema,
  faqSchema,
  eyebrow,
  h1,
  intro,
  heroImage,
  heroAlt,
  proof = [],
  trust = [],
  introHeading,
  introParagraphs = [],
  bookingTitle,
  bookingText,
  bookingItems = [],
  problemEyebrow,
  problemHeading,
  problems = [],
  safetyHeading,
  safetyParagraphs = [],
  safetyItems = [],
  servicesEyebrow = "Related electrical service",
  servicesHeading = "Choose the next electrical service path",
  relatedServices = [],
  photoEyebrow,
  photoHeading,
  photoText,
  photoItems = [],
  photoImage,
  photoAlt,
  proofHeading,
  proofText,
  proofCards = [],
  processHeading,
  processSteps = [],
  areaText,
  ctaEyebrow,
  ctaHeading,
  ctaText,
  faqEyebrow,
  faqHeading,
  faqs = [],
  breadcrumbs = [],
} = Astro.props;

const electricalServiceFallbacks = [
  { title: "Generator Installation", href: "/generator-installation.html", text: "Backup power planning, panel readiness, and safe generator connection review.", link: "View generator service", icon: "M4 16h16 M6 16V8h12v8 M8 8V5h8v3 M9 12h2 M13 12h2 M17 12h1" },
  { title: "Subpanel Installation", href: "/subpanel-installation.html", text: "Additional circuit planning for garages, basements, workshops, additions, and equipment areas.", link: "View subpanel service", icon: "M6 4v16 M6 8h8a4 4 0 0 1 0 8H6" },
  { title: "Surge Protection", href: "/surge-protection.html", text: "Panel-based surge protection planning for electronics, appliances, and sensitive equipment.", link: "View surge protection", icon: "M12 3 5 6v6c0 4.5 3 7.5 7 9 4-1.5 7-4.5 7-9V6z" },
  { title: "Pot Light Installation", href: "/pot-light-installation.html", text: "Clean recessed lighting plans for kitchens, basements, living rooms, and work spaces.", link: "View pot lights", icon: "M6 5h12 M8 5l2 8h4l2-8 M9 17h6 M10 21h4" },
  { title: "Ceiling Fan Installation", href: "/ceiling-fan-installation.html", text: "Ceiling fan wiring, replacement, support review, and switch control planning.", link: "View ceiling fans", icon: "M12 11a2 2 0 1 0 0 4 2 2 0 0 0 0-4z M12 11c-1-4 1-7 4-7 2 0 3 1 3 3 0 3-3 4-7 4z M12 13c4-1 7 1 7 4 0 2-1 3-3 3-3 0-4-3-4-7z M12 13c-3 3-6 3-8 1-1-1-1-3 0-4 2-2 5-1 8 3z" },
  { title: "Smart Home Wiring", href: "/smart-home-wiring.html", text: "Smart switches, controls, low-voltage planning, and connected home electrical setup.", link: "View smart wiring", icon: "M4 12h4l2-6 4 12 2-6h4 M5 20h14 M7 4h10" },
  { title: "Outdoor Lighting", href: "/outdoor-lighting.html", text: "Exterior lighting plans for entrances, pathways, garages, yards, and security visibility.", link: "View outdoor lighting", icon: "M4 20h16 M6 20v-8l6-5 6 5v8 M9 20v-5h6v5 M8 7l4-3 4 3" },
  { title: "Driveway Lighting", href: "/driveway-lighting.html", text: "Driveway, garage approach, pathway, and motion lighting planned for outdoor visibility.", link: "View driveway lighting", icon: "M4 20h16 M6 16h12 M8 16l4-10 4 10 M9 10h6" },
  { title: "New Construction Electrician", href: "/new-construction-electrician.html", text: "Electrical rough-in planning for new builds, additions, lighting, panels, and circuits.", link: "View new construction", icon: "M3 11 12 4l9 7v9H5v-9z M8 20v-6h8v6" },
  { title: "Electrical Panel Upgrade", href: "/panel-upgrade.html", text: "Panel capacity planning for renovations, EV charging, added circuits, and safer distribution.", link: "View panel upgrades", icon: "M5 4h14v18H5z M9 8h6 M9 12h2 M13 12h2 M9 16h2 M13 16h2" },
  { title: "Electrical Repair", href: "/electrical-repair.html", text: "Troubleshooting for outlets, switches, breakers, fixtures, partial power, and urgent issues.", link: "View electrical repair", icon: "M14 3l7 7-4 1-1 4-4 1-1 4-7-7 4-1 1-4 4-1z" },
  { title: "House Rewiring", href: "/house-rewiring.html", text: "Wiring updates for older homes, renovations, additions, outlets, lighting, and circuits.", link: "View house rewiring", icon: "M6 4v16 M6 8h8a4 4 0 0 1 0 8H6" },
  { title: "Outlet & Switch Install", href: "/outlet-switch-install.html", text: "Outlet, switch, dimmer, timer, and smart control installation planning.", link: "View outlet service", icon: "M13 2 5 14h6l-1 8 9-13h-6z" },
  { title: "Electrical Safety Inspection", href: "/electrical-safety-inspection.html", text: "Safety review for panels, breakers, outlets, wiring concerns, and older homes.", link: "View safety inspection", icon: "M12 3 5 6v6c0 4.5 3 7.5 7 9 4-1.5 7-4.5 7-9V6z" },
  { title: "Smoke & CO Detectors", href: "/smoke-co-detectors.html", text: "Smoke alarm and carbon monoxide detector installation or replacement review.", link: "View detector service", icon: "M12 3 5 6v6c0 4.5 3 7.5 7 9 4-1.5 7-4.5 7-9V6z" },
];

const currentPath = canonical ? new URL(canonical).pathname : "";
const hideVisibleBreadcrumbPaths = new Set([
  "/generator-installation.html",
  "/subpanel-installation.html",
  "/surge-protection.html",
  "/pot-light-installation.html",
  "/ceiling-fan-installation.html",
  "/smart-home-wiring.html",
  "/outdoor-lighting.html",
  "/driveway-lighting.html",
  "/new-construction-electrician.html",
  "/panel-upgrade.html",
  "/electrical-repair.html",
  "/house-rewiring.html",
  "/outlet-switch-install.html",
  "/electrical-safety-inspection.html",
  "/smoke-co-detectors.html",
]);
const showVisibleBreadcrumbs = breadcrumbs.length > 0 && !hideVisibleBreadcrumbPaths.has(currentPath);
const toRootHref = (href = "") => href.startsWith("http") || href.startsWith("/") || href.startsWith("tel:") || href.startsWith("mailto:") ? href : `/${href}`;
const normalizedRelatedServices = [...relatedServices, ...electricalServiceFallbacks].reduce((services, service) => {
  const href = toRootHref(service.href);
  if (href === currentPath || services.some((item) => item.href === href)) return services;
  services.push({ ...service, href });
  return services;
}, []).slice(0, 8);
const introSummaryItems = bookingItems.slice(0, 4);
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <SiteHeader />

  {showVisibleBreadcrumbs && (
    <nav class="breadcrumb-nav" aria-label="Breadcrumb">
      <div class="breadcrumb-list">
        {breadcrumbs.map((crumb, index) => (
          <>
            {index > 0 && <span class="breadcrumb-separator" aria-hidden="true">/</span>}
            {index < breadcrumbs.length - 1 ? <a href={toRootHref(crumb.href)}>{crumb.label}</a> : <span aria-current="page">{crumb.label}</span>}
          </>
        ))}
      </div>
    </nav>
  )}

  <main class="page-hero electrical-page-hero">
    <div>
      <p class="eyebrow">{eyebrow}</p>
      <h1>{h1}</h1>
      <p>{intro}</p>
      <div class="hero-actions">
        <a class="button" href="tel:+16479809211">Call 647-980-9211</a>
        <a class="button secondary" href="contact.html">Request service</a>
      </div>
      <div class="hero-proof-row" aria-label="Service highlights">
        {proof.map((item) => <span>{item}</span>)}
      </div>
    </div>
    <div class="hero-service-card">
      <img src={heroImage} alt={heroAlt} width="760" height="520">
    </div>
  </main>

  <section class="home-trust-banner electrical-trust-banner" aria-label="Electrical service highlights">
    {trust.map((item) => (
      <article class="trust-feature">
        <span class="trust-feature-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d={item.icon}></path></svg>
        </span>
        <div>
          <h2>{item.title}</h2>
          <p>{item.text}</p>
        </div>
      </article>
    ))}
  </section>

  <section class="content plumber-intro electrical-content-section electrical-intro-section">
    <div class="electrical-copy">
      <p class="eyebrow">Local electrical service</p>
      <h2>{introHeading}</h2>
      {introParagraphs.map((text) => <p>{text}</p>)}
      {introSummaryItems.length > 0 && (
        <div class="electrical-inline-panel">
          <h3>What we can help with</h3>
          <ul>
            {introSummaryItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      )}
    </div>
    <aside class="quick-card booking-card">
      <p class="eyebrow">Need help?</p>
      <h2>{bookingTitle}</h2>
      <p>{bookingText}</p>
      <a class="button" href="tel:+16479809211">Call 647-980-9211</a>
      <a class="button secondary" href="contact.html">Request service online</a>
    </aside>
  </section>

  <section class="band problem-band electrical-problem-band">
    <div class="section-heading">
      <p class="eyebrow">{problemEyebrow}</p>
      <h2>{problemHeading}</h2>
    </div>
    <div class="problem-grid">
      {problems.map((problem) => (
        <article>
          <strong>{problem.title}</strong>
          <p>{problem.text}</p>
          <a href={problem.href}>{problem.link}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="content electrical-content-section electrical-planning-section">
    <div class="electrical-copy">
      <p class="eyebrow">Service planning</p>
      <h2>{safetyHeading}</h2>
      {safetyParagraphs.map((text) => <p>{text}</p>)}
    </div>
    <aside class="quick-card urgent-card">
      <h2>Helpful details to mention</h2>
      <ul class="check-list">
        {safetyItems.map((item) => <li>{item}</li>)}
      </ul>
    </aside>
  </section>

  <section class="band service-hub-band electrical-hub-band">
    <div class="section-heading">
      <p class="eyebrow">{servicesEyebrow}</p>
      <h2>{servicesHeading}</h2>
    </div>
    <div class="service-hub-grid">
      {normalizedRelatedServices.map((service) => (
        <article>
          <span class="hub-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d={service.icon}></path></svg>
          </span>
          <h3><a href={service.href}>{service.title}</a></h3>
          <p>{service.text}</p>
          <a class="text-link" href={service.href}>{service.link}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="photo-feature-section">
    <div class="photo-feature-copy">
      <p class="eyebrow">{photoEyebrow}</p>
      <h2>{photoHeading}</h2>
      <p>{photoText}</p>
      <ul class="check-list">
        {photoItems.map((item) => <li>{item}</li>)}
      </ul>
      <a class="button" href="tel:+16479809211">Call 647-980-9211</a>
    </div>
    <div class="photo-feature-media">
      <img src={photoImage} alt={photoAlt} width="760" height="560" loading="lazy">
    </div>
  </section>

  <section class="proof-band">
    <div>
      <p class="eyebrow">Why choose Fateh</p>
      <h2>{proofHeading}</h2>
      <p>{proofText}</p>
    </div>
    <div class="proof-grid">
      {proofCards.map((card) => <article><strong>{card.title}</strong><span>{card.text}</span></article>)}
    </div>
  </section>

  <section class="review-showcase" aria-labelledby="review-showcase-title">
    <div class="review-showcase-head">
      <div>
        <p class="eyebrow">Customer feedback</p>
        <h2 id="review-showcase-title">What people are saying about Fateh Plumbing & Electric</h2>
      </div>
      <div class="review-score-card" aria-label="Google Business Profile rating">
        <span class="review-source">Google Business Profile</span>
        <strong>4.6/5</strong>
        <span class="stars" aria-label="Five star rating">★★★★★</span>
        <small>Based on 185 Google reviews</small>
      </div>
    </div>
    <div class="review-carousel" data-review-carousel>
      <button class="review-nav review-prev" type="button" data-review-prev aria-label="Previous review">‹</button>
      <div class="review-window">
        <div class="review-track">
          {[
            ["Kulvinder S", "The customer appreciated clear communication, careful work, and a professional service visit from start to finish.", "Professional home service"],
            ["Massagical C", "Fateh fit the job into a busy schedule, answered questions in detail, and helped the customer understand the next step.", "Troubleshooting help"],
            ["Jennifer M", "A late-night issue was handled quickly and professionally, giving the homeowner timely help when the repair felt stressful.", "Emergency service"],
            ["Dipesh S", "The technician arrived on time, explained the installation process, finished carefully, and left the workspace clean.", "Installation service"],
            ["Ama A", "The work was completed cleanly and tested before the customer used the space again.", "Home service call"],
            ["Nav", "The technician arrived fast, completed the work cleanly, and the customer felt the price was reasonable.", "Fast repair visit"],
            ["Mellad A", "An urgent service call received a quick response, honest communication, and a repair the customer described positively.", "Urgent service call"],
          ].map(([name, text, label]) => (
            <article class="review-card">
              <div class="review-card-head"><span class="google-word" aria-label="Google"><span>G</span><span>o</span><span>o</span><span>g</span><span>l</span><span>e</span></span><strong>{name}</strong></div>
              <div class="stars" aria-hidden="true">★★★★★</div>
              <p>{text}</p>
              <small>{label}</small>
            </article>
          ))}
        </div>
      </div>
      <button class="review-nav review-next" type="button" data-review-next aria-label="Next review">›</button>
      <div class="review-dots" aria-hidden="true"></div>
    </div>
  </section>

  <section class="band process-band electrical-process-band">
    <div class="section-heading">
      <p class="eyebrow">How service works</p>
      <h2>{processHeading}</h2>
    </div>
    <div class="process-steps">
      {processSteps.map((step, index) => <article><span>{index + 1}</span><h3>{step.title}</h3><p>{step.text}</p></article>)}
    </div>
  </section>

  <section class="content neighbourhood-section electrical-content-section electrical-area-section">
    <div class="electrical-copy">
      <p class="eyebrow">Brampton service areas</p>
      <h2>Electrical help across Brampton neighbourhoods</h2>
      <p>{areaText}</p>
      <p>We help homes, rental units, restaurants, retail spaces, small businesses, and managed properties across Brampton and nearby GTA communities.</p>
    </div>
    <aside class="quick-card area-card">
      <h2>Areas we serve</h2>
      <div class="area-tags">
        {["Bramalea", "Springdale", "Castlemore", "Mount Pleasant", "Heart Lake", "Fletcher's Meadow", "Credit Valley", "Peel Village", "Downtown Brampton"].map((area) => <span>{area}</span>)}
      </div>
    </aside>
  </section>

  <section class="brampton-cta-band electrical-cta-band">
    <div>
      <p class="eyebrow">{ctaEyebrow}</p>
      <h2>{ctaHeading}</h2>
      <p>{ctaText}</p>
    </div>
    <a class="button" href="tel:+16479809211">Call 647-980-9211</a>
  </section>

  <section class="band faq">
    <div class="section-heading">
      <p class="eyebrow">{faqEyebrow}</p>
      <h2>{faqHeading}</h2>
    </div>
    {faqs.map((faq) => <details><summary>{faq.question}</summary><p>{faq.answer}</p></details>)}
  </section>

  <SiteFooter />
</BaseLayout>
