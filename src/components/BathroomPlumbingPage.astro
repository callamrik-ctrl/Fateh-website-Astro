---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "./SiteHeader.astro";
import SiteFooter from "./SiteFooter.astro";

const {
  title,
  description,
  canonical,
  eyebrow,
  h1,
  heroText,
  heroImage,
  heroAlt,
  proof = [],
  trust = [],
  intro,
  quickCard,
  problems = [],
  process = [],
  compare,
  related = [],
  serviceArea = {},
  proofBand,
  relatedEyebrow = "Related bathroom plumbing services",
  relatedTitle = "Bathroom service paths",
  cta = {
    eyebrow: "Book service",
    title: "Need bathroom plumbing help in Brampton?",
    text: "Call Fateh Plumbing & Electric for clear bathroom fixture service, practical repair options, and help for homes, rentals, condos, and small businesses.",
    button: "Call 647-980-9211",
  },
  faqEyebrow = "FAQ",
  faqTitle = "Common questions before booking bathroom plumbing service",
  faqs = [],
} = Astro.props;

const plumberSchema = {
  "@context": "https://schema.org",
  "@type": "Plumber",
  name: "Fateh Plumbing & Electric",
  url: canonical,
  telephone: "647-980-9211",
  email: "info@fatehplumelec.com",
  image: "https://fatehplumelec.com/assets/fateh-logo-clean.png",
  logo: "https://fatehplumelec.com/assets/fateh-logo-clean.png",
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Brampton",
    addressRegion: "ON",
    addressCountry: "CA",
  },
  areaServed: ["Brampton", "Bramalea", "Springdale", "Castlemore", "Mount Pleasant", "Heart Lake", "Mississauga", "Vaughan", "Caledon", "Etobicoke"],
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
      opens: "00:00",
      closes: "23:59",
    },
  ],
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: h1,
  serviceType: title.split("|")[0].trim(),
  provider: {
    "@type": "LocalBusiness",
    name: "Fateh Plumbing & Electric",
    telephone: "647-980-9211",
  },
  areaServed: {
    "@type": "City",
    name: "Brampton",
  },
  url: canonical,
  description,
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.a,
    },
  })),
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(plumberSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <SiteHeader />

  <main class="page-hero brampton-plumber-hero kitchen-service-hero">
    <div>
      <p class="eyebrow">{eyebrow}</p>
      <h1>{h1}</h1>
      <p>{heroText}</p>
      <div class="hero-actions">
        <a class="button" href="tel:+16479809211">Call 647-980-9211</a>
        <a class="button secondary" href="contact.html">Request service</a>
      </div>
      <div class="hero-proof-row" aria-label="Service highlights">
        {proof.map((item) => <span>{item}</span>)}
      </div>
    </div>
    <div class="hero-service-card">
      <img src={heroImage} alt={heroAlt} width="760" height="520">
    </div>
  </main>

  <section class="home-trust-banner plumber-trust-banner" aria-label="Bathroom service highlights">
    {trust.map((item) => (
      <article class="trust-feature">
        <span class="trust-feature-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M5 12h14"></path><path d="M7 8v8"></path><path d="M17 8v8"></path><path d="M9 18h6"></path></svg>
        </span>
        <div>
          <h2>{item.title}</h2>
          <p>{item.text}</p>
        </div>
      </article>
    ))}
  </section>

  <section class="content plumber-intro">
    <div>
      <p class="eyebrow">{intro.eyebrow}</p>
      <h2>{intro.title}</h2>
      {intro.paragraphs.map((paragraph) => <p set:html={paragraph} />)}
    </div>
    <aside class="quick-card booking-card">
      <p class="eyebrow">{quickCard.eyebrow}</p>
      <h2>{quickCard.title}</h2>
      <p>{quickCard.text}</p>
      <a class="button" href="tel:+16479809211">Call 647-980-9211</a>
      <a class="button secondary" href="contact.html">Request service</a>
      <ul class="mini-links">
        {quickCard.points.map((point) => <li>{point}</li>)}
      </ul>
    </aside>
  </section>

  <section class="band problem-band">
    <div class="section-heading">
      <p class="eyebrow">{problems.eyebrow}</p>
      <h2>{problems.title}</h2>
    </div>
    <div class="problem-grid">
      {problems.items.map((item) => (
        <article>
          <strong>{item.title}</strong>
          <p>{item.text}</p>
          <a href={item.href}>{item.link}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="band process-band">
    <div class="section-heading">
      <p class="eyebrow">{process.eyebrow}</p>
      <h2>{process.title}</h2>
    </div>
    <div class="process-steps">
      {process.items.map((item, index) => (
        <article>
          <span>{index + 1}</span>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="content plumber-intro">
    <div>
      <p class="eyebrow">{compare.eyebrow}</p>
      <h2>{compare.title}</h2>
      {compare.paragraphs.map((paragraph) => <p set:html={paragraph} />)}
    </div>
    <aside class="quick-card">
      <h2>{compare.cardTitle}</h2>
      <ul class="check-list">
        {compare.points.map((point) => <li>{point}</li>)}
      </ul>
    </aside>
  </section>

  <section class="bathroom-coverage-band">
    <div>
      <p class="eyebrow">{serviceArea.eyebrow || "Service coverage"}</p>
      <h2>{serviceArea.title || "Bathroom plumbing help across Brampton and nearby GTA communities"}</h2>
      <p>{serviceArea.text || "Fateh Plumbing & Electric helps homeowners, landlords, condos, and small businesses with bathroom plumbing repairs from Brampton into nearby service areas when scheduling allows."}</p>
      <ul>
        {(serviceArea.points || ["Brampton", "Mississauga", "Vaughan", "Caledon", "Etobicoke"]).map((point) => <li>{point}</li>)}
      </ul>
    </div>
    <div class="coverage-map-card" aria-label="Brampton and nearby GTA service area map">
      <iframe
        title="Brampton and nearby GTA service area map"
        src="https://www.google.com/maps?q=Brampton%20Ontario%20Canada&output=embed"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>
  </section>

  <section class="band service-hub-band">
    <div class="section-heading">
      <p class="eyebrow">{relatedEyebrow}</p>
      <h2>{relatedTitle}</h2>
    </div>
    <div class="service-hub-grid">
      {related.map((item) => (
        <article>
          <span class="hub-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M4 11h16"></path><path d="M6 11v5a4 4 0 0 0 4 4h4a4 4 0 0 0 4-4v-5"></path><path d="M8 6h8"></path></svg>
          </span>
          <h3><a href={item.href}>{item.title}</a></h3>
          <p>{item.text}</p>
          <a class="text-link" href={item.href}>{item.link}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="proof-band">
    <div>
      <p class="eyebrow">{proofBand.eyebrow}</p>
      <h2>{proofBand.title}</h2>
      <p>{proofBand.text}</p>
    </div>
    <div class="proof-grid">
      {proofBand.items.map((item) => (
        <article>
          <strong>{item.title}</strong>
          <span>{item.text}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="brampton-cta-band">
    <div>
      <p class="eyebrow">{cta.eyebrow}</p>
      <h2>{cta.title}</h2>
      <p>{cta.text}</p>
    </div>
    <a class="button" href="tel:+16479809211">{cta.button}</a>
  </section>

  <section class="band faq">
    <div class="section-heading">
      <p class="eyebrow">{faqEyebrow}</p>
      <h2>{faqTitle}</h2>
    </div>
    {faqs.map((faq) => (
      <details>
        <summary>{faq.q}</summary>
        <p>{faq.a}</p>
      </details>
    ))}
  </section>

  <SiteFooter />
</BaseLayout>
