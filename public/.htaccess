RewriteEngine On

RewriteCond %{HTTP_HOST} ^www\.fatehplumelec\.com$ [NC]
RewriteRule ^(.*)$ https://fatehplumelec.com/$1 [R=301,L]

# Old service-area clean URLs
RewriteRule ^service-areas/brampton/?$ /brampton-plumber.html [R=301,L]
